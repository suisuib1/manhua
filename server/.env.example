PORT=3000
DATABASE_URL="postgresql://postgres:password@127.0.0.1:5432/manhua?schema=public"
JWT_SECRET="please-change-me"
JWT_EXPIRES_IN="7d"

# Local mock login:
# WECHAT_LOGIN_MOCK="true"
#
# Real WeChat login:
# WECHAT_LOGIN_MOCK="false"
# WECHAT_APP_ID="your-miniprogram-appid"
# WECHAT_APP_SECRET="your-miniprogram-appsecret"
#
# Keep AppSecret only in server/.env. Do not put it in frontend code.
WECHAT_APP_ID=""
WECHAT_APP_SECRET=""
WECHAT_LOGIN_MOCK="true"
