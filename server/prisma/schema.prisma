generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  wxOpenid     String?       @unique @map("wx_openid")
  wxUnionid    String?       @map("wx_unionid")
  status       String        @default("active")
  lastLoginAt  DateTime?     @map("last_login_at")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  profile      UserProfile?
  setting      UserSetting?
  comicBooks   ComicBook[]
  quota        UserQuota?
  characterProfile CharacterProfile?
  diaryEntries DiaryEntry[]
  diaryPhotos  DiaryPhoto[]
  generationTasks GenerationTask[]

  @@map("users")
}

model UserProfile {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  nickname  String?
  avatarUrl String?  @map("avatar_url")
  bio       String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model UserSetting {
  id                  String   @id @default(cuid())
  userId              String   @unique @map("user_id")
  autoSaveDraft       Boolean  @default(true) @map("auto_save_draft")
  keepPhotoMood       Boolean  @default(true) @map("keep_photo_mood")
  privateMode         Boolean  @default(true) @map("private_mode")
  diaryReminder       Boolean  @default(false) @map("diary_reminder")
  generationReminder  Boolean  @default(true) @map("generation_reminder")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model ComicBook {
  id             String   @id @default(cuid())
  ownerUserId    String   @map("owner_user_id")
  title          String   @default("我的漫画日记")
  description    String?
  coverImageUrl  String?  @map("cover_image_url")
  visibility     String   @default("private")
  sortOrder      Int      @default(0) @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  owner User @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@index([ownerUserId])
  @@index([ownerUserId, sortOrder])
  @@map("comic_books")
}

model UserQuota {
  id              String   @id @default(cuid())
  userId          String   @unique @map("user_id")
  totalQuota      Int      @default(0) @map("total_quota")
  usedQuota       Int      @default(0) @map("used_quota")
  remainingQuota  Int      @default(0) @map("remaining_quota")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_quotas")
}

model CharacterProfile {
  id                 String   @id @default(cuid())
  ownerUserId        String   @unique @map("owner_user_id")
  nickname           String?
  roleTitle          String?  @map("role_title")
  description        String?
  personalityText    String?  @map("personality_text")
  appearanceText     String?  @map("appearance_text")
  referenceImageUrl  String?  @map("reference_image_url")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  owner User @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@map("character_profiles")
}

model DiaryEntry {
  id                String       @id @default(cuid())
  ownerUserId       String       @map("owner_user_id")
  chapterTitle      String?      @map("chapter_title")
  diaryDate         DateTime?    @map("diary_date")
  diaryText         String?      @map("diary_text")
  pageCount         Int          @default(4) @map("page_count")
  pageMode          String?      @map("page_mode")
  selectedTagsJson  String       @default("[]") @map("selected_tags_json")
  status            String       @default("draft")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")
  deletedAt         DateTime?    @map("deleted_at")

  owner  User         @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  photos DiaryPhoto[]
  generationTasks GenerationTask[]

  @@index([ownerUserId])
  @@index([ownerUserId, status])
  @@index([ownerUserId, diaryDate])
  @@index([ownerUserId, createdAt])
  @@map("diary_entries")
}

model DiaryPhoto {
  id            String      @id @default(cuid())
  diaryEntryId  String      @map("diary_entry_id")
  ownerUserId   String      @map("owner_user_id")
  imageUrl      String      @map("image_url")
  originalName  String?     @map("original_name")
  mimeType      String?     @map("mime_type")
  sizeBytes     Int?        @map("size_bytes")
  sortOrder     Int         @default(0) @map("sort_order")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  deletedAt     DateTime?   @map("deleted_at")

  diaryEntry DiaryEntry @relation(fields: [diaryEntryId], references: [id], onDelete: Cascade)
  owner      User       @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@index([diaryEntryId])
  @@index([ownerUserId])
  @@index([diaryEntryId, sortOrder])
  @@map("diary_photos")
}

model GenerationTask {
  id              String    @id @default(cuid())
  ownerUserId     String    @map("owner_user_id")
  diaryEntryId    String?   @map("diary_entry_id")
  status          String    @default("pending")
  taskType        String    @default("diary_to_comic") @map("task_type")
  promptSnapshot  String?   @map("prompt_snapshot")
  inputJson       String    @default("{}") @map("input_json")
  resultJson      String?   @map("result_json")
  errorMessage    String?   @map("error_message")
  retryCount      Int       @default(0) @map("retry_count")
  startedAt       DateTime? @map("started_at")
  finishedAt      DateTime? @map("finished_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  owner      User        @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  diaryEntry DiaryEntry? @relation(fields: [diaryEntryId], references: [id], onDelete: SetNull)

  @@index([ownerUserId])
  @@index([ownerUserId, status])
  @@index([diaryEntryId])
  @@index([createdAt])
  @@map("generation_tasks")
}
