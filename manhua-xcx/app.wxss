/**app.wxss**/
.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: 200rpx 0;
  box-sizing: border-box;
}

.polish-page {
  min-height: 100vh;
  padding: 34rpx 28rpx 58rpx;
  box-sizing: border-box;
  color: #50332a;
  background:
    radial-gradient(circle at 10% 6%, rgba(255, 226, 176, 0.38), transparent 220rpx),
    radial-gradient(circle at 88% 15%, rgba(255, 216, 224, 0.4), transparent 260rpx),
    #fffaf5;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

.polish-header {
  padding: 18rpx 8rpx 16rpx;
  text-align: center;
}

.polish-title {
  color: #4a2b22;
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1.2;
}

.polish-subtitle {
  margin-top: 18rpx;
  color: #75574c;
  font-size: 26rpx;
  line-height: 1.5;
}

.polish-card {
  position: relative;
  margin-top: 28rpx;
  padding: 28rpx;
  box-sizing: border-box;
  border: 2rpx solid #efd8cc;
  border-radius: 32rpx;
  background: rgba(255, 254, 250, 0.94);
  box-shadow: 0 12rpx 30rpx rgba(114, 75, 54, 0.09);
}

.polish-card::before {
  content: "";
  position: absolute;
  inset: 12rpx;
  border: 2rpx dashed rgba(239, 196, 188, 0.72);
  border-radius: 24rpx;
  pointer-events: none;
}

.polish-card-content {
  position: relative;
  z-index: 1;
}

.polish-card-title {
  color: #4d3029;
  font-size: 31rpx;
  font-weight: 800;
  line-height: 1.3;
}

.polish-card-desc {
  margin-top: 12rpx;
  color: #7d5d52;
  font-size: 25rpx;
  line-height: 1.6;
}

.polish-note {
  position: relative;
  margin-top: 24rpx;
  padding: 22rpx 26rpx;
  border: 2rpx solid #f1cd9a;
  border-radius: 24rpx;
  color: #6e4c40;
  font-size: 25rpx;
  line-height: 1.6;
  background: #fff7e8;
}

.polish-primary,
.polish-secondary {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 620rpx;
  max-width: 100%;
  height: 96rpx;
  margin: 30rpx auto 0;
  border-radius: 999rpx;
  font-size: 31rpx;
  font-weight: 800;
  line-height: 1;
}

.polish-primary {
  border: 4rpx solid #ffffff;
  color: #ffffff;
  background: linear-gradient(180deg, #ff96a7 0%, #f77187 100%);
  box-shadow: 0 16rpx 30rpx rgba(238, 98, 119, 0.23);
}

.polish-secondary {
  border: 2rpx solid #f0d6c8;
  color: #7b5b51;
  background: rgba(255, 253, 249, 0.92);
}

.polish-button-hover {
  opacity: 0.86;
  transform: translateY(2rpx);
}

.polish-chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.polish-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 58rpx;
  padding: 0 24rpx;
  border: 2rpx solid #f0d6c8;
  border-radius: 999rpx;
  color: #70493f;
  font-size: 24rpx;
  background: #fff9f1;
}

.polish-chip.is-selected {
  border-color: #ff8091;
  color: #ef5f74;
  background: #fffafa;
}
