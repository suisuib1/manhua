<view class="home-page">
  <view class="greeting-card">
    <view class="greeting-copy">
      <view class="greeting-title">{{user.greetingTitle}}，</view>
      <view class="greeting-text">{{user.greetingText}}</view>
    </view>
    <view class="mascot-wrap">
      <image class="home-mascot" src="/subpackage/icon-home-mascot-star.png" mode="aspectFit" />
    </view>
  </view>

  <view class="book-card">
    <image class="home-decor-icon book-heart-decor" src="/subpackage/icon-home-heart.png" mode="aspectFit" />
    <image class="home-decor-icon book-star-decor" src="/subpackage/icon-home-star-badge.png" mode="aspectFit" />
    <image class="home-decor-icon book-smile-decor" src="/subpackage/icon-home-smile.png" mode="aspectFit" />
    <image class="book-cover-image" src="/subpackage/icon-home-mascot-star.png" mode="aspectFill" />
    <view class="book-info">
      <view class="book-title">{{defaultComicBook.title}}</view>
      <view class="privacy-pill">{{defaultComicBook.privacyLabel}}</view>
      <view class="book-desc">{{defaultComicBook.description}}</view>
      <view class="book-meta">已收藏 {{defaultComicBook.chapterCount}} 个章节</view>
    </view>
  </view>

  <button class="create-button" hover-class="create-button-hover" bindtap="goCreateChapter">
    <image class="create-button-icon" src="/subpackage/icon-home-pencil.png" mode="aspectFit" />
    <text>写今天的漫画日记</text>
  </button>

  <view class="quota-line">
    <text class="quota-star">☆</text>
    <text>{{quotaHint}}：</text>
    <text class="quota-count">{{freeQuotaRemaining}}次</text>
  </view>

  <view class="section-card chapters-card">
    <view class="section-head">
      <view class="section-title">
        <text>最近章节</text>
      </view>
    </view>

    <view wx:if="{{isRecentChaptersEmpty}}" class="recent-empty">
      <view class="recent-empty-title">还没有漫画章节</view>
      <view class="recent-empty-text">写一篇日记，生成你的第一章漫画吧</view>
      <button class="recent-empty-button" hover-class="button-hover" bindtap="goCreateChapter">去写日记</button>
    </view>

    <scroll-view wx:else class="chapter-scroll" scroll-x="true" enable-flex="true">
      <view
        wx:for="{{recentChapters}}"
        wx:key="id"
        class="chapter-card"
        data-id="{{item.id}}"
        bindtap="goChapterDetail"
      >
        <image class="chapter-cover-image" src="{{item.coverImageUrl || '/subpackage/icon-home-mascot-star.png'}}" mode="aspectFill" />
        <view class="chapter-copy">
          <view class="chapter-title">{{item.title}}</view>
          <view class="chapter-subtitle">{{item.displaySubtitle || item.subtitle}}</view>
          <view class="chapter-meta">
            <text class="chapter-date">{{item.displayDate}}</text>
            <text wx:if="{{item.statusText}}" class="chapter-state-text {{item.statusClass}}">{{item.statusText}}</text>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="quick-grid">
    <view class="quick-card character-card" bindtap="goCharacter">
      <image class="home-entry-icon" src="/subpackage/icon-home-character-profile.png" mode="aspectFit" />
      <view class="quick-copy">
        <view class="quick-title">角色档案</view>
        <view class="quick-desc">管理你的专属角色和故事设定</view>
      </view>
      <view class="quick-arrow">›</view>
    </view>

    <view class="quick-card mine-card" bindtap="goMine">
      <image class="home-entry-icon" src="/subpackage/icon-home-settings-book.png" mode="aspectFit" />
      <view class="quick-copy">
        <view class="quick-title">我的 / 设置</view>
        <view class="quick-desc">隐私与偏好设置安心记录</view>
      </view>
      <view class="quick-arrow">›</view>
    </view>
  </view>
</view>
