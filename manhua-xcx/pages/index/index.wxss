page {
  min-height: 100%;
  background: #fffaf5;
  color: #50332a;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

button {
  margin: 0;
  padding: 0;
  background: transparent;
  line-height: 1;
  border: 0;
  border-radius: 0;
}

button::after {
  border: 0;
}

.home-navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 20;
  background: #fffaf5;
}

.home-nav-title {
  position: absolute;
  left: 168rpx;
  right: 168rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #4a2b22;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.2;
  text-align: center;
}

.home-page {
  min-height: 100vh;
  padding: 34rpx 28rpx 56rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 12% 7%, rgba(255, 226, 176, 0.4), transparent 220rpx),
    radial-gradient(circle at 86% 16%, rgba(255, 214, 224, 0.42), transparent 250rpx),
    #fffaf5;
}

.button-hover {
  opacity: 0.74;
}

.greeting-card {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 164rpx;
  margin-top: 16rpx;
  padding: 28rpx 26rpx 26rpx 30rpx;
  box-sizing: border-box;
  border: 3rpx solid #d9bda9;
  border-radius: 44rpx 44rpx 72rpx 44rpx;
  background: rgba(255, 253, 248, 0.72);
}

.greeting-card::after {
  content: "";
  position: absolute;
  right: 132rpx;
  bottom: -18rpx;
  width: 56rpx;
  height: 34rpx;
  border-right: 3rpx solid #d9bda9;
  border-bottom: 3rpx solid #d9bda9;
  border-radius: 0 0 28rpx 0;
  background: #fffaf5;
  transform: rotate(20deg);
}

.greeting-copy {
  position: relative;
  z-index: 1;
  flex: 1;
  min-width: 0;
}

.greeting-title {
  color: #f08a25;
  font-size: 48rpx;
  font-weight: 800;
  line-height: 1.05;
}

.greeting-text {
  margin-top: 18rpx;
  color: #4f3028;
  font-size: 28rpx;
  font-weight: 500;
  line-height: 1.45;
}

.mascot-wrap {
  position: relative;
  flex: 0 0 148rpx;
  width: 148rpx;
  height: 144rpx;
  margin-left: 14rpx;
  z-index: 1;
}

.home-mascot {
  width: 148rpx;
  height: 144rpx;
  display: block;
}

.book-card {
  position: relative;
  display: flex;
  align-items: center;
  min-height: 292rpx;
  margin-top: 48rpx;
  padding: 30rpx;
  box-sizing: border-box;
  border: 3rpx solid #f2b3aa;
  border-radius: 34rpx;
  background: linear-gradient(180deg, #fffdf9 0%, #fff5ee 100%);
  box-shadow: 0 16rpx 38rpx rgba(187, 93, 76, 0.16);
}

.book-card::before {
  content: "";
  position: absolute;
  inset: 16rpx;
  border: 2rpx dashed #f2beb6;
  border-radius: 28rpx;
  pointer-events: none;
}

.home-decor-icon {
  position: absolute;
  z-index: 2;
  display: block;
  pointer-events: none;
}

.book-heart-decor {
  right: 18rpx;
  top: 70rpx;
  width: 42rpx;
  height: 42rpx;
}

.book-star-decor {
  right: 18rpx;
  top: 132rpx;
  width: 44rpx;
  height: 44rpx;
}

.book-smile-decor {
  right: 18rpx;
  top: 196rpx;
  width: 42rpx;
  height: 42rpx;
}

.book-cover-image {
  flex: 0 0 224rpx;
  width: 224rpx;
  height: 224rpx;
  border: 3rpx solid #dab19e;
  border-radius: 28rpx;
  display: block;
  overflow: hidden;
  box-sizing: border-box;
}

.book-info {
  position: relative;
  z-index: 1;
  flex: 1;
  min-width: 0;
  padding-left: 34rpx;
}

.book-title {
  color: #553229;
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.2;
}

.privacy-pill {
  display: inline-flex;
  align-items: center;
  margin-top: 20rpx;
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  color: #b96468;
  font-size: 24rpx;
  background: #ffe4e4;
}

.privacy-pill::before {
  content: "";
  width: 14rpx;
  height: 14rpx;
  margin-right: 10rpx;
  border-radius: 50%;
  background: #ee8990;
}

.book-desc {
  margin-top: 24rpx;
  color: #815c50;
  font-size: 26rpx;
  line-height: 1.6;
}

.book-meta {
  margin-top: 10rpx;
  color: #b0887a;
  font-size: 22rpx;
}

.create-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 600rpx;
  max-width: 100%;
  height: 96rpx;
  margin: 34rpx auto 0;
  border: 4rpx solid #ffffff;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  background: linear-gradient(180deg, #ff94a4 0%, #f77186 100%);
  box-shadow: 0 16rpx 30rpx rgba(238, 98, 119, 0.24);
}

.create-button-hover {
  transform: translateY(2rpx);
  opacity: 0.9;
}

.create-button-icon {
  flex: 0 0 58rpx;
  width: 58rpx;
  height: 58rpx;
  margin-right: 18rpx;
  display: block;
}

.quota-line {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 24rpx;
  color: #8d7166;
  font-size: 25rpx;
}

.quota-star {
  margin-right: 8rpx;
  color: #f5b844;
  font-size: 30rpx;
}

.quota-count {
  color: #f25f78;
  font-weight: 700;
}

.section-card {
  margin-top: 30rpx;
  padding: 28rpx 20rpx 24rpx;
  border: 2rpx solid #ead6ca;
  border-radius: 28rpx;
  background: rgba(255, 254, 250, 0.9);
  box-shadow: 0 10rpx 30rpx rgba(109, 74, 57, 0.08);
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 4rpx 22rpx;
}

.section-title {
  display: flex;
  align-items: center;
  color: #4b3028;
  font-size: 32rpx;
  font-weight: 800;
}

.chapter-scroll {
  width: 100%;
  white-space: nowrap;
}

.chapter-card {
  display: inline-flex;
  flex-direction: column;
  width: 202rpx;
  min-height: 366rpx;
  margin-right: 18rpx;
  padding: 16rpx;
  box-sizing: border-box;
  border: 2rpx solid #efd9cc;
  border-radius: 24rpx;
  background: #fffdf9;
  vertical-align: top;
}

.chapter-card:last-child {
  margin-right: 0;
}

.chapter-cover-image {
  width: 100%;
  height: 148rpx;
  border-radius: 18rpx;
  display: block;
  overflow: hidden;
}

.chapter-title {
  margin-top: 14rpx;
  color: #4d322b;
  font-size: 27rpx;
  font-weight: 800;
}

.chapter-subtitle {
  margin-top: 8rpx;
  color: #5f443b;
  font-size: 23rpx;
  line-height: 1.3;
  white-space: normal;
}

.chapter-date {
  margin-top: 10rpx;
  color: #9d8174;
  font-size: 23rpx;
}

.chapter-summary {
  height: 60rpx;
  margin-top: 10rpx;
  color: #a48678;
  font-size: 20rpx;
  line-height: 1.45;
  white-space: normal;
  overflow: hidden;
}

.memory-note {
  position: relative;
  display: flex;
  align-items: center;
  min-height: 126rpx;
  margin-top: 28rpx;
  padding: 24rpx 188rpx 24rpx 120rpx;
  box-sizing: border-box;
  border: 2rpx solid #f0d6ab;
  border-radius: 28rpx;
  background: #fff7e8;
}

.memory-note::before {
  content: "";
  position: absolute;
  inset: 12rpx;
  border: 2rpx dashed #f0c88f;
  border-radius: 22rpx;
}

.note-pin {
  position: absolute;
  left: 52rpx;
  top: -18rpx;
  width: 32rpx;
  height: 58rpx;
  border: 4rpx solid #d9a565;
  border-bottom: 0;
  border-radius: 18rpx 18rpx 0 0;
  transform: rotate(-8deg);
}

.memory-copy {
  position: relative;
  z-index: 1;
  color: #6d4a3e;
  font-size: 26rpx;
  line-height: 1.6;
}

.home-empty-cat {
  position: absolute;
  right: 34rpx;
  bottom: 16rpx;
  width: 138rpx;
  height: 92rpx;
  z-index: 1;
  display: block;
}

.quick-grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 20rpx;
  margin-top: 28rpx;
}

.quick-card {
  display: flex;
  align-items: center;
  min-height: 126rpx;
  padding: 20rpx 20rpx 20rpx 16rpx;
  box-sizing: border-box;
  border: 2rpx solid rgba(225, 202, 188, 0.86);
  border-radius: 26rpx;
  background: rgba(255, 255, 252, 0.88);
}

.character-card {
  background: linear-gradient(145deg, #fbfff2 0%, #f6fff1 100%);
}

.mine-card {
  background: linear-gradient(145deg, #fbf7ff 0%, #f7f1ff 100%);
}

.home-entry-icon {
  flex: 0 0 70rpx;
  width: 70rpx;
  height: 70rpx;
  display: block;
}

.quick-copy {
  flex: 1;
  min-width: 0;
  margin-left: 16rpx;
}

.quick-title {
  color: #4f362f;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 1.2;
}

.quick-desc {
  margin-top: 9rpx;
  color: #8b756b;
  font-size: 21rpx;
  line-height: 1.42;
}

.quick-arrow {
  margin-left: 8rpx;
  color: #8daf7c;
  font-size: 50rpx;
  line-height: 1;
}

.mine-card .quick-arrow {
  color: #ab8bc5;
}
