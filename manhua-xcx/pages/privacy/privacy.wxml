<view class="info-page">
  <view class="info-hero">
    <view class="hero-icon">私</view>
    <view class="hero-copy">
      <view class="hero-title">隐私说明</view>
      <view class="hero-desc">安心把日记变成漫画，原文和未授权内容不对外公开。</view>
    </view>
  </view>

  <view class="info-card">
    <view wx:for="{{sections}}" wx:key="title" class="info-row">
      <view class="row-dot"></view>
      <view class="row-copy">
        <view class="row-title">{{item.title}}</view>
        <view class="row-desc">{{item.desc}}</view>
      </view>
    </view>
  </view>
</view>
