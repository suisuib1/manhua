page {
  min-height: 100%;
  background: #fffaf5;
}

button {
  margin: 0;
  padding: 0;
  background: transparent;
  border: 0;
  line-height: 1;
  text-align: left;
}

button::after {
  border: 0;
}

.book-profile {
  border-color: #f0b4a8;
  background: linear-gradient(180deg, #fffdf9 0%, #fff4ee 100%);
  box-shadow: 0 18rpx 36rpx rgba(210, 102, 92, 0.14);
}

.book-profile-content {
  display: flex;
  align-items: center;
  gap: 26rpx;
}

.book-cover-mini {
  flex: 0 0 166rpx;
  width: 166rpx;
  height: 190rpx;
  border: 3rpx solid #dab19e;
  border-radius: 28rpx;
  background: linear-gradient(160deg, #cae8ff 0%, #fff3cd 58%, #d8edbe 100%);
  overflow: hidden;
}

.book-cover-mini-image {
  display: block;
  width: 100%;
  height: 100%;
}

.book-copy {
  flex: 1;
  min-width: 0;
}

.user-name {
  color: #4a2b22;
  font-size: 42rpx;
  font-weight: 800;
}

.user-subtitle {
  margin-top: 12rpx;
  color: #75574c;
  font-size: 25rpx;
  line-height: 1.45;
}

.book-title {
  display: inline-flex;
  margin-top: 18rpx;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  color: #c66d75;
  font-size: 23rpx;
  background: #ffe8ea;
}

.stats-card {
  padding: 22rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
}

.stat-item {
  padding: 22rpx 8rpx;
  border-radius: 22rpx;
  text-align: center;
  background: #fff7ef;
}

.stat-number {
  color: #ef6e83;
  font-size: 38rpx;
  font-weight: 800;
}

.stat-label {
  margin-top: 8rpx;
  color: #92786e;
  font-size: 23rpx;
}

.quota-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.quota-title {
  color: #4d3029;
  font-size: 29rpx;
  font-weight: 800;
}

.quota-desc {
  margin-top: 8rpx;
  color: #8d7166;
  font-size: 23rpx;
}

.quota-number {
  flex: 0 0 auto;
  color: #ef6e83;
  font-size: 38rpx;
  font-weight: 800;
}

.menu-card {
  padding: 12rpx 0;
}

.menu-card::before {
  display: none;
}

.menu-card .polish-card-content {
  width: 100%;
  padding: 0;
  box-sizing: border-box;
}

.menu-row {
  display: flex;
  align-items: center;
  width: 100%;
  min-height: 118rpx;
  padding: 0 28rpx;
  box-sizing: border-box;
  border-bottom: 2rpx solid #f3e6dd;
}

.menu-row:last-child {
  border-bottom: 0;
}

.menu-icon {
  position: relative;
  flex: 0 0 58rpx;
  width: 58rpx;
  height: 58rpx;
  margin-right: 18rpx;
  border-radius: 20rpx;
  background: #ffe8ea;
}

.menu-icon::after {
  content: "";
  position: absolute;
  left: 18rpx;
  top: 18rpx;
  width: 22rpx;
  height: 22rpx;
  border-radius: 50%;
  background: #ef7185;
}

.icon-1 {
  background: #fff0c7;
}

.icon-1::after {
  background: #e7aa3a;
}

.icon-2 {
  background: #eef7e9;
}

.icon-2::after {
  background: #8daf7c;
}

.icon-3 {
  background: #f3e9ff;
}

.icon-3::after {
  background: #ab8bc5;
}

.menu-copy {
  flex: 1;
  min-width: 0;
}

.menu-title {
  color: #4d3029;
  font-size: 29rpx;
  font-weight: 800;
}

.menu-desc {
  margin-top: 8rpx;
  color: #92786e;
  font-size: 23rpx;
  line-height: 1.35;
}

.menu-arrow {
  color: #b69d92;
  font-size: 48rpx;
}
