<view class="settings-page polish-page">
  <view class="settings-section">
    <view class="settings-section-title">账号</view>
    <view class="settings-list">
      <view class="setting-row" bindtap="handleAccountTap" hover-class="settings-row-hover">
        <view class="setting-main">
          <view class="setting-title">个人资料</view>
        </view>
        <view class="setting-side">
          <view class="setting-value muted">{{user.nickname}}</view>
          <view class="setting-arrow">›</view>
        </view>
      </view>

      <view class="setting-row" bindtap="handleAccountTap" hover-class="settings-row-hover">
        <view class="setting-main">
          <view class="setting-title">登录状态</view>
        </view>
        <view class="setting-side">
          <view class="setting-value accent">{{user.loginText}}</view>
          <view class="setting-arrow">›</view>
        </view>
      </view>
    </view>
  </view>

  <view class="settings-section">
    <view class="settings-section-title">创作偏好</view>
    <view class="settings-list">
      <view class="setting-row" bindtap="handleStyleTap" hover-class="settings-row-hover">
        <view class="setting-main">
          <view class="setting-title">默认漫画风格</view>
        </view>
        <view class="setting-side">
          <view class="setting-value accent">Q版</view>
        </view>
      </view>

      <view class="setting-row">
        <view class="setting-main">
          <view class="setting-title">自动保存草稿</view>
        </view>
        <switch
          class="setting-switch"
          checked="{{settings.autoSaveDraft}}"
          data-key="autoSaveDraft"
          bindchange="handleToggleChange"
          color="#f77187"
        />
      </view>

      <view class="setting-row">
        <view class="setting-main">
          <view class="setting-title">生成时保留照片情绪</view>
        </view>
        <switch
          class="setting-switch"
          checked="{{settings.keepPhotoMood}}"
          data-key="keepPhotoMood"
          bindchange="handleToggleChange"
          color="#f77187"
        />
      </view>
    </view>
  </view>

  <view class="settings-section">
    <view class="settings-section-title">隐私与数据</view>
    <view class="settings-list">
      <view class="setting-row">
        <view class="setting-main">
          <view class="setting-title">私密日记模式</view>
        </view>
        <switch
          class="setting-switch"
          checked="{{settings.privateMode}}"
          data-key="privateMode"
          bindchange="handleToggleChange"
          color="#f77187"
        />
      </view>

      <view class="setting-row" bindtap="clearDraftCache" hover-class="settings-row-hover">
        <view class="setting-main">
          <view class="setting-title">清理临时草稿缓存</view>
          <view class="setting-desc">draftComicChapter</view>
        </view>
        <view class="setting-side">
          <view class="setting-value accent">清理</view>
        </view>
      </view>

      <view class="setting-row" bindtap="clearGeneratedCache" hover-class="settings-row-hover">
        <view class="setting-main">
          <view class="setting-title">清理本地生成缓存</view>
          <view class="setting-desc">generatedComicChapters</view>
        </view>
        <view class="setting-side">
          <view class="setting-value accent">清理</view>
        </view>
      </view>
    </view>
  </view>

  <view class="settings-section">
    <view class="settings-section-title">通知提醒</view>
    <view class="settings-list">
      <view class="setting-row">
        <view class="setting-main">
          <view class="setting-title">每日写日记提醒</view>
        </view>
        <switch
          class="setting-switch"
          checked="{{settings.diaryReminder}}"
          data-key="diaryReminder"
          bindchange="handleToggleChange"
          color="#f77187"
        />
      </view>

      <view class="setting-row">
        <view class="setting-main">
          <view class="setting-title">漫画生成完成提醒</view>
        </view>
        <switch
          class="setting-switch"
          checked="{{settings.generationReminder}}"
          data-key="generationReminder"
          bindchange="handleToggleChange"
          color="#f77187"
        />
      </view>
    </view>
  </view>

  <view class="settings-section">
    <view class="settings-section-title">帮助与关于</view>
    <view class="settings-list">
      <view class="setting-row" data-action="faq" bindtap="handleHelpTap" hover-class="settings-row-hover">
        <view class="setting-main">
          <view class="setting-title">常见问题</view>
        </view>
        <view class="setting-side">
          <view class="setting-arrow">›</view>
        </view>
      </view>

      <view class="setting-row" data-action="feedback" bindtap="handleHelpTap" hover-class="settings-row-hover">
        <view class="setting-main">
          <view class="setting-title">意见反馈</view>
        </view>
        <view class="setting-side">
          <view class="setting-arrow">›</view>
        </view>
      </view>

      <view class="setting-row" data-action="privacy" bindtap="handleHelpTap" hover-class="settings-row-hover">
        <view class="setting-main">
          <view class="setting-title">隐私协议</view>
        </view>
        <view class="setting-side">
          <view class="setting-arrow">›</view>
        </view>
      </view>

      <view class="setting-row" data-action="version" bindtap="handleHelpTap" hover-class="settings-row-hover">
        <view class="setting-main">
          <view class="setting-title">当前版本</view>
        </view>
        <view class="setting-side">
          <view class="setting-value muted">{{versionText}}</view>
        </view>
      </view>
    </view>
  </view>

  <button class="logout-button" bindtap="handleLogoutTap">退出登录</button>
</view>
