page {
  min-height: 100%;
  background: #f6f6f6;
  color: #1f1f1f;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

button {
  margin: 0;
  padding: 0;
  background: transparent;
  border: 0;
  line-height: 1;
  border-radius: 0;
}

button::after {
  border: 0;
}

.settings-page {
  min-height: 100vh;
  padding: 18rpx 0 56rpx;
  background: #f6f6f6;
}

.settings-section {
  margin-top: 24rpx;
}

.settings-section:first-child {
  margin-top: 8rpx;
}

.settings-section-title {
  padding: 0 32rpx 12rpx;
  color: #8a8a8a;
  font-size: 26rpx;
  line-height: 1.2;
}

.settings-list {
  background: #ffffff;
}

.setting-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 112rpx;
  padding: 0 32rpx;
  box-sizing: border-box;
  background: #ffffff;
}

.setting-row + .setting-row {
  border-top: 1rpx solid #eeeeee;
}

.settings-row-hover {
  background: #f7f7f7;
}

.setting-main {
  flex: 1;
  min-width: 0;
  padding-right: 24rpx;
}

.setting-title {
  color: #222222;
  font-size: 32rpx;
  font-weight: 400;
  line-height: 1.3;
}

.setting-desc {
  margin-top: 6rpx;
  color: #b0b0b0;
  font-size: 22rpx;
  line-height: 1.35;
}

.setting-side {
  display: flex;
  align-items: center;
  flex: 0 0 auto;
  min-width: 0;
}

.setting-value {
  color: #999999;
  font-size: 28rpx;
  line-height: 1.2;
}

.setting-value.accent {
  color: #e56c86;
}

.setting-value.muted {
  max-width: 220rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.setting-arrow {
  margin-left: 12rpx;
  color: #b8b8b8;
  font-size: 44rpx;
  line-height: 1;
}

.setting-switch {
  flex: 0 0 auto;
  transform: scale(0.9);
  transform-origin: center right;
}

.logout-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: calc(100% - 64rpx);
  height: 96rpx;
  margin: 40rpx 32rpx 0;
  border-radius: 16rpx;
  color: #e56c86;
  font-size: 30rpx;
  font-weight: 400;
  background: #ffffff;
  border: 0;
}
