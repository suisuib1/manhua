page {
  min-height: 100%;
  background: #fff9f7;
  color: #1f1f1f;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

button {
  margin: 0;
  padding: 0;
  background: transparent;
  border: 0;
  line-height: 1;
  border-radius: 0;
}

button::after {
  border: 0;
}

.settings-page {
  min-height: 100vh;
  padding: 28rpx 0 56rpx;
  background: #fff9f7;
}

.settings-form {
  width: calc(100% - 78rpx);
  margin: 0 auto;
  border-radius: 22rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 44rpx rgba(179, 126, 112, 0.08);
  overflow: hidden;
}

.setting-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 104rpx;
  padding: 0 34rpx;
  box-sizing: border-box;
  background: #ffffff;
}

.setting-row + .setting-row {
  border-top: 1rpx solid #eeeeee;
}

.settings-row-hover {
  background: #fff6f7;
}

.setting-icon {
  position: relative;
  flex: 0 0 44rpx;
  width: 44rpx;
  height: 44rpx;
  margin-right: 26rpx;
  box-sizing: border-box;
  color: #ff6f8a;
}

.setting-main {
  flex: 1;
  min-width: 0;
  padding-right: 24rpx;
}

.setting-title {
  color: #222222;
  font-size: 31rpx;
  font-weight: 400;
  line-height: 1.3;
}

.setting-side {
  display: flex;
  align-items: center;
  flex: 0 0 auto;
  min-width: 0;
}

.setting-value {
  color: #999999;
  font-size: 30rpx;
  line-height: 1.2;
}

.setting-value.accent {
  color: #ff6f8a;
}

.setting-value.muted {
  max-width: 220rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.setting-arrow {
  margin-left: 18rpx;
  color: #a8a8a8;
  font-size: 48rpx;
  line-height: 1;
}

.setting-switch {
  flex: 0 0 auto;
  transform: scale(0.86);
  transform-origin: center right;
}

.logout-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: calc(100% - 78rpx);
  height: 96rpx;
  margin: 34rpx auto 0;
  border-radius: 22rpx;
  color: #ff6f8a;
  font-size: 30rpx;
  font-weight: 400;
  background: #ffffff;
  border: 0;
  box-shadow: 0 18rpx 44rpx rgba(179, 126, 112, 0.08);
}

.icon-user::before,
.icon-user::after,
.icon-lock::before,
.icon-lock::after,
.icon-palette::before,
.icon-save::before,
.icon-save::after,
.icon-smile::before,
.icon-smile::after,
.icon-clean::before,
.icon-clean::after,
.icon-box::before,
.icon-box::after,
.icon-bell::before,
.icon-bell::after,
.icon-help::before {
  position: absolute;
  content: "";
  box-sizing: border-box;
}

.icon-user::before {
  left: 14rpx;
  top: 5rpx;
  width: 17rpx;
  height: 17rpx;
  border: 3rpx solid currentColor;
  border-radius: 50%;
}

.icon-user::after {
  left: 7rpx;
  bottom: 4rpx;
  width: 30rpx;
  height: 20rpx;
  border: 3rpx solid currentColor;
  border-radius: 18rpx 18rpx 4rpx 4rpx;
}

.icon-lock::before {
  left: 9rpx;
  top: 18rpx;
  width: 28rpx;
  height: 22rpx;
  border: 3rpx solid currentColor;
  border-radius: 6rpx;
}

.icon-lock::after {
  left: 14rpx;
  top: 5rpx;
  width: 18rpx;
  height: 22rpx;
  border: 3rpx solid currentColor;
  border-bottom: 0;
  border-radius: 16rpx 16rpx 0 0;
}

.icon-palette::before {
  left: 5rpx;
  top: 6rpx;
  width: 34rpx;
  height: 34rpx;
  border: 3rpx solid currentColor;
  border-radius: 50%;
}

.icon-palette::after {
  right: 5rpx;
  bottom: 8rpx;
  width: 13rpx;
  height: 13rpx;
  border: 3rpx solid currentColor;
  border-radius: 50%;
  background: #ffffff;
  box-shadow: -17rpx -9rpx 0 -3rpx #ffffff, -17rpx -9rpx 0 0 currentColor;
}

.icon-save::before {
  left: 8rpx;
  top: 8rpx;
  width: 29rpx;
  height: 31rpx;
  border: 3rpx solid currentColor;
  border-radius: 6rpx;
}

.icon-save::after {
  left: 14rpx;
  top: 8rpx;
  width: 17rpx;
  height: 11rpx;
  border: 3rpx solid currentColor;
  border-top: 0;
  border-radius: 0 0 4rpx 4rpx;
}

.icon-smile::before {
  left: 5rpx;
  top: 5rpx;
  width: 34rpx;
  height: 34rpx;
  border: 3rpx solid currentColor;
  border-radius: 50%;
}

.icon-smile::after {
  left: 14rpx;
  top: 16rpx;
  width: 16rpx;
  height: 13rpx;
  border-bottom: 3rpx solid currentColor;
  border-radius: 0 0 16rpx 16rpx;
  box-shadow: -6rpx -5rpx 0 -2rpx currentColor, 6rpx -5rpx 0 -2rpx currentColor;
}

.icon-clean::before {
  left: 19rpx;
  top: 6rpx;
  width: 8rpx;
  height: 22rpx;
  border: 3rpx solid currentColor;
  border-bottom: 0;
  border-radius: 8rpx 8rpx 0 0;
}

.icon-clean::after {
  left: 8rpx;
  top: 24rpx;
  width: 28rpx;
  height: 14rpx;
  border: 3rpx solid currentColor;
  border-radius: 2rpx 2rpx 10rpx 10rpx;
}

.icon-box::before {
  left: 7rpx;
  top: 13rpx;
  width: 31rpx;
  height: 24rpx;
  border: 3rpx solid currentColor;
  border-radius: 5rpx;
}

.icon-box::after {
  left: 12rpx;
  top: 8rpx;
  width: 21rpx;
  height: 11rpx;
  border: 3rpx solid currentColor;
  border-radius: 5rpx 5rpx 0 0;
}

.icon-bell::before {
  left: 10rpx;
  top: 7rpx;
  width: 25rpx;
  height: 29rpx;
  border: 3rpx solid currentColor;
  border-radius: 18rpx 18rpx 8rpx 8rpx;
}

.icon-bell::after {
  left: 8rpx;
  top: 33rpx;
  width: 29rpx;
  height: 3rpx;
  border-radius: 999rpx;
  background: currentColor;
}

.icon-help::before {
  left: 6rpx;
  top: 6rpx;
  width: 33rpx;
  height: 33rpx;
  border: 3rpx solid currentColor;
  border-radius: 50%;
}

.icon-help {
  font-size: 26rpx;
  line-height: 44rpx;
  text-align: center;
}

.icon-help::after {
  content: "?";
  color: currentColor;
  font-size: 26rpx;
  line-height: 44rpx;
}
