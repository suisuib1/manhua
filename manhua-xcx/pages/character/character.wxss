page {
  min-height: 100%;
  background: #fffaf5;
}

button {
  margin: 0;
  padding: 0;
  background: transparent;
  border: 0;
  line-height: 1;
}

button::after {
  border: 0;
}

.character-page {
  padding-top: 96rpx;
}

.profile-cover {
  min-height: 234rpx;
  border-color: #f0b4a8;
  background: linear-gradient(145deg, #fffdf9 0%, #fff4ee 100%);
  box-shadow: 0 18rpx 36rpx rgba(210, 102, 92, 0.15);
}

.cover-content {
  display: flex;
  align-items: center;
  gap: 28rpx;
  min-height: 180rpx;
}

.profile-photo {
  flex: 0 0 168rpx;
  width: 168rpx;
  height: 168rpx;
  border: 3rpx solid #efc6b6;
  border-radius: 30rpx;
  background: linear-gradient(160deg, #dff1ff 0%, #fff1c8 56%, #f6d7e4 100%);
  overflow: hidden;
}

.profile-image {
  display: block;
  width: 100%;
  height: 100%;
}

.cover-copy {
  flex: 1;
  min-width: 0;
}

.cover-kicker {
  color: #9c7a6d;
  font-size: 24rpx;
  line-height: 1.5;
}

.cover-title {
  margin-top: 16rpx;
  color: #4d3029;
  font-size: 42rpx;
  font-weight: 800;
}

.cover-desc {
  margin-top: 12rpx;
  color: #7d5d52;
  font-size: 25rpx;
}

.cover-star {
  position: absolute;
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #ffd66b;
}

.star-one {
  right: 44rpx;
  top: 36rpx;
}

.star-two {
  right: 86rpx;
  bottom: 44rpx;
  background: #ff9daf;
}

.profile-form {
  background: rgba(255, 254, 250, 0.96);
}

.form-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.field-block {
  min-width: 0;
}

.full-field {
  margin-top: 24rpx;
}

.field-label {
  color: #4d3029;
  font-size: 28rpx;
  font-weight: 800;
}

.field-input,
.field-static {
  display: flex;
  align-items: center;
  height: 78rpx;
  margin-top: 14rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  border: 2rpx solid #f1d5cc;
  border-radius: 22rpx;
  color: #6a382e;
  font-size: 26rpx;
  background: #fffdfb;
}

.field-static {
  color: #9a7b70;
}

.desc-input {
  width: 100%;
  min-height: 164rpx;
  margin-top: 14rpx;
  padding: 22rpx;
  box-sizing: border-box;
  border: 2rpx solid #f1d5cc;
  border-radius: 24rpx;
  color: #5c3b33;
  font-size: 26rpx;
  line-height: 1.6;
  background: #fffdfb;
}

.input-placeholder {
  color: #c8aaa0;
}

.tag-section {
  margin-top: 26rpx;
}

.tag-section .polish-chip-row {
  margin-top: 16rpx;
}

.reference-row {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 28rpx;
}

.reference-card,
.reference-add {
  height: 126rpx;
  border-radius: 22rpx;
  border: 2rpx solid #efd4c8;
}

.reference-card {
  display: block;
  width: 100%;
  box-sizing: border-box;
  overflow: hidden;
}

.reference-add {
  display: flex;
  align-items: center;
  justify-content: center;
  border-style: dashed;
  color: #ef7185;
  font-size: 44rpx;
  font-weight: 800;
  background: #fffdf9;
}

.character-note {
  padding-left: 28rpx;
}

.note-line {
  color: #715247;
  font-size: 25rpx;
  line-height: 1.65;
}

.note-line + .note-line {
  margin-top: 8rpx;
}
