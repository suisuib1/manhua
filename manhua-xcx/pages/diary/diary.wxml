<view class="diary-page polish-page">
  <view class="polish-header diary-header">
    <view class="polish-title">{{mock.title}}</view>
    <view class="polish-subtitle">{{mock.subtitle}}</view>
  </view>

  <view class="diary-book polish-card">
    <view class="polish-card-content">
      <view class="book-ring ring-one"></view>
      <view class="book-ring ring-two"></view>
      <view class="diary-book-head">
        <view>
          <view class="polish-card-title">今天的日记</view>
          <view class="diary-book-desc">{{mock.chapterSummary.title}} · {{mock.chapterSummary.pageModeText}}</view>
        </view>
        <view class="diary-count">{{textCount}} / {{mock.diaryTextMaxLength}}</view>
      </view>
      <textarea
        class="diary-textarea"
        value="{{diaryText}}"
        maxlength="{{mock.diaryTextMaxLength}}"
        placeholder="{{mock.diaryPlaceholder}}"
        placeholder-class="input-placeholder"
        bindinput="onDiaryInput"
      />
      <view class="polish-chip-row diary-tags">
        <text wx:for="{{mock.chapterSummary.tags}}" wx:key="*this" class="polish-chip">#{{item}}</text>
      </view>
    </view>
  </view>

  <view class="privacy-note polish-note">
    <view class="note-badge">隐私</view>
    <view class="note-copy">{{mock.privacyHint}}</view>
  </view>

  <view class="photo-card polish-card">
    <view class="polish-card-content">
      <view class="photo-card-head">
        <view>
          <view class="polish-card-title">照片贴纸</view>
          <view class="polish-card-desc">选择 1-9 张最能代表今天故事的照片</view>
        </view>
        <view class="photo-limit">{{photoList.length}} / {{mock.photoLimit}}</view>
      </view>
      <view class="photo-grid">
        <view
          wx:for="{{photoList}}"
          wx:key="id"
          class="photo-tile {{item.tone}}"
        >
          <view class="photo-sky"></view>
          <view class="photo-hill"></view>
          <view class="photo-label">{{item.label}}</view>
          <button class="photo-remove" data-id="{{item.id}}" bindtap="removePhoto">×</button>
        </view>
        <button class="photo-add" bindtap="addPhotoPlaceholder" hover-class="polish-button-hover">
          <view class="add-plus">+</view>
          <view>继续添加</view>
        </button>
      </view>
      <view class="photo-tip">建议选择最能代表今天故事的照片，后续会帮助漫画分镜更丰富。</view>
    </view>
  </view>

  <view class="check-card polish-card">
    <view class="polish-card-content check-content">
      <view>
        <view class="polish-card-title">生成前检查</view>
        <view class="check-line">日记内容已填写</view>
        <view class="check-line">照片记录已准备</view>
        <view class="check-line">{{mock.characterHint}}</view>
      </view>
      <view class="check-mascot">
        <view class="check-face"></view>
        <view class="check-glass"></view>
      </view>
    </view>
  </view>

  <button class="polish-primary" bindtap="goGenerating" hover-class="polish-button-hover">
    提交并开始生成
  </button>
</view>
