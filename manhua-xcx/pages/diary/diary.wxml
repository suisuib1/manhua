<view class="diary-page">
  <view class="diary-card">
    <view class="card-head">
      <view>
        <view class="card-title">今天的日记</view>
        <view class="card-desc">{{mock.chapterSummary.title}} · {{mock.chapterSummary.pageModeText}}</view>
      </view>
      <view class="count-pill">{{textCount}} / {{mock.diaryTextMaxLength}}</view>
    </view>
    <textarea
      class="diary-textarea"
      value="{{diaryText}}"
      maxlength="{{mock.diaryTextMaxLength}}"
      placeholder="{{mock.diaryPlaceholder}}"
      placeholder-class="input-placeholder"
      bindinput="onDiaryInput"
    />
    <view class="diary-tags">
      <text wx:for="{{mock.chapterSummary.tags}}" wx:key="*this" class="diary-tag">#{{item}}</text>
    </view>
  </view>

  <view class="privacy-note">
    <view class="privacy-badge">隐私</view>
    <view class="privacy-copy">{{mock.privacyHint}}</view>
  </view>

  <button class="generate-button" bindtap="goGenerating" hover-class="button-hover">
    生成我的漫画
  </button>
</view>
