page {
  min-height: 100%;
  background: #fffaf5;
  color: #4f3028;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

view,
text,
button,
textarea {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  background: transparent;
  border: 0;
  border-radius: 0;
  line-height: normal;
}

button::after {
  border: 0;
}

.diary-page {
  width: 100%;
  min-height: 100vh;
  padding: 24rpx 24rpx 240rpx;
  overflow-x: hidden;
  background: #fffaf5;
}

.diary-card {
  width: 100%;
  margin-bottom: 24rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: #fffaf4;
  box-shadow: 0 14rpx 32rpx rgba(116, 76, 58, 0.08);
}

.card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  width: 100%;
}

.card-title {
  color: #4d3029;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.35;
}

.card-desc {
  margin-top: 10rpx;
  color: #9a8177;
  font-size: 23rpx;
  line-height: 1.45;
}

.count-pill {
  flex: 0 0 auto;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  color: #c66d75;
  font-size: 22rpx;
  font-weight: 700;
  background: #ffe8ea;
}

.diary-textarea {
  display: block;
  width: 100%;
  min-height: 260rpx;
  margin-top: 24rpx;
  padding: 24rpx;
  border: 2rpx solid #f7d8d0;
  border-radius: 24rpx;
  color: #5c3b33;
  font-size: 28rpx;
  line-height: 1.6;
  background: #fffdf9;
}

.input-placeholder {
  color: #c8aaa0;
  font-size: 26rpx;
  line-height: 1.6;
}

.diary-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  width: 100%;
  margin-top: 18rpx;
}

.diary-tag {
  max-width: 100%;
  padding: 9rpx 18rpx;
  border-radius: 999rpx;
  color: #9a665e;
  font-size: 23rpx;
  line-height: 1.2;
  background: #fff0e8;
}

.privacy-note {
  display: flex;
  align-items: flex-start;
  width: 100%;
  margin-bottom: 24rpx;
  padding: 20rpx 24rpx;
  border: 2rpx solid #f3e5dc;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 24rpx rgba(146, 101, 62, 0.06);
}

.privacy-badge {
  flex: 0 0 auto;
  margin-right: 16rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: #c66d75;
  font-size: 22rpx;
  font-weight: 800;
  background: #ffe8ea;
}

.privacy-copy {
  flex: 1;
  min-width: 0;
  color: #7a5a4f;
  font-size: 24rpx;
  line-height: 1.55;
}

.generate-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 78%;
  height: 88rpx;
  margin: 30rpx auto 0;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 800;
  background: linear-gradient(180deg, #ff96a7 0%, #f77187 100%);
  box-shadow: 0 16rpx 30rpx rgba(238, 98, 119, 0.22);
}

.button-hover {
  opacity: 0.82;
}
