page {
  min-height: 100%;
  background: #fffaf5;
}

button {
  margin: 0;
  padding: 0;
  background: transparent;
  border: 0;
  line-height: 1;
}

button::after {
  border: 0;
}

.diary-header {
  padding-bottom: 6rpx;
}

.diary-book {
  margin-top: 24rpx;
  padding: 34rpx 30rpx 30rpx 42rpx;
  border-color: #f0a9a1;
  border-radius: 36rpx;
  background: linear-gradient(180deg, #fffdf9 0%, #fff4ee 100%);
  box-shadow: 0 18rpx 36rpx rgba(210, 102, 92, 0.16);
}

.book-ring {
  position: absolute;
  left: -18rpx;
  width: 42rpx;
  height: 62rpx;
  border: 6rpx solid #f4ada4;
  border-right: 0;
  border-radius: 26rpx 0 0 26rpx;
  background: #fffaf5;
}

.ring-one {
  top: 92rpx;
}

.ring-two {
  top: 242rpx;
}

.diary-book-head,
.photo-card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.diary-book-desc {
  margin-top: 12rpx;
  color: #8d7166;
  font-size: 24rpx;
}

.diary-count,
.photo-limit {
  flex: 0 0 auto;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  color: #c66d75;
  font-size: 22rpx;
  background: #ffe8ea;
}

.diary-textarea {
  width: 100%;
  min-height: 300rpx;
  margin-top: 24rpx;
  padding: 24rpx;
  box-sizing: border-box;
  border: 2rpx solid #f3ded5;
  border-radius: 24rpx;
  color: #5c3b33;
  font-size: 28rpx;
  line-height: 1.7;
  background: rgba(255, 255, 252, 0.82);
}

.input-placeholder {
  color: #c8aaa0;
}

.diary-tags {
  margin-top: 18rpx;
}

.privacy-note {
  display: flex;
  align-items: center;
}

.note-badge {
  flex: 0 0 auto;
  margin-right: 18rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  color: #c66d75;
  font-size: 23rpx;
  font-weight: 800;
  background: #ffe8ea;
}

.note-copy {
  flex: 1;
}

.photo-card {
  background: linear-gradient(180deg, #fffdf9 0%, #fff9f2 100%);
}

.photo-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 24rpx;
}

.photo-tile,
.photo-add {
  position: relative;
  height: 150rpx;
  overflow: hidden;
  border: 2rpx solid #efd4c8;
  border-radius: 24rpx;
  color: #765248;
  font-size: 23rpx;
  background: #fff8ef;
}

.photo-tile.mint {
  background: #f3fbef;
}

.photo-sky {
  position: absolute;
  left: 16rpx;
  top: 16rpx;
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  background: #ffd96a;
}

.photo-hill {
  position: absolute;
  left: 12rpx;
  right: 12rpx;
  bottom: 24rpx;
  height: 56rpx;
  border-radius: 60rpx 60rpx 20rpx 20rpx;
  background: rgba(183, 226, 173, 0.75);
}

.photo-label {
  position: absolute;
  left: 12rpx;
  right: 12rpx;
  bottom: 14rpx;
  text-align: center;
  font-weight: 700;
}

.photo-remove {
  position: absolute;
  right: 8rpx;
  top: 8rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  color: #ffffff;
  font-size: 28rpx;
  background: rgba(226, 120, 128, 0.9);
}

.photo-add {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-style: dashed;
  color: #ef7185;
  background: #fffdf9;
}

.add-plus {
  margin-bottom: 12rpx;
  font-size: 46rpx;
  font-weight: 800;
}

.photo-tip {
  margin-top: 18rpx;
  color: #8d7166;
  font-size: 23rpx;
  line-height: 1.5;
}

.check-card {
  background: #fff7e8;
}

.check-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 22rpx;
}

.check-line {
  margin-top: 12rpx;
  color: #715247;
  font-size: 24rpx;
  line-height: 1.45;
}

.check-line::before {
  content: "";
  display: inline-block;
  width: 18rpx;
  height: 18rpx;
  margin-right: 10rpx;
  border-radius: 50%;
  background: #ff96a7;
}

.check-mascot {
  position: relative;
  flex: 0 0 116rpx;
  width: 116rpx;
  height: 108rpx;
}

.check-face {
  position: absolute;
  right: 8rpx;
  top: 12rpx;
  width: 78rpx;
  height: 78rpx;
  border-radius: 50%;
  background: #ffd8c8;
  box-shadow: -18rpx -12rpx 0 rgba(184, 130, 96, 0.22);
}

.check-glass {
  position: absolute;
  right: 0;
  bottom: 6rpx;
  width: 44rpx;
  height: 44rpx;
  border: 6rpx solid #87a9c8;
  border-radius: 50%;
}
