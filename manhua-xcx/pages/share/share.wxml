<view class="share-page">
  <view class="page-header">
    <view class="privacy-pill">{{mock.visibility}}</view>
    <view class="page-title">章节私密分享</view>
    <view class="page-subtitle">只有拿到链接的人才能查看这一章</view>
  </view>

  <view class="preview-card">
    <view class="chapter-title">{{mock.title}}</view>
    <view class="chapter-date">{{mock.date}}</view>
    <view class="preview-grid">
      <view
        wx:for="{{mock.comicPreview}}"
        wx:key="id"
        class="preview-cover {{item.tone}}"
      >
        <view class="preview-sun"></view>
        <view class="preview-title">{{item.title}}</view>
      </view>
    </view>
    <view class="summary-copy">{{mock.summary}}</view>
  </view>

  <view class="link-card">
    <view class="card-title">{{mock.linkStatus}}</view>
    <view class="link-box">{{mock.shareUrl}}</view>
    <view wx:for="{{mock.notes}}" wx:key="*this" class="note-line">{{item}}</view>
  </view>

  <view class="action-grid">
    <button class="secondary-button" bindtap="copyLink" hover-class="button-hover">复制链接</button>
    <button class="primary-button" bindtap="shareToWechat" hover-class="button-hover">微信分享</button>
  </view>

  <button class="text-button" bindtap="goHome">返回首页</button>
</view>
