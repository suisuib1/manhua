<view class="share-page polish-page">
  <view class="polish-header">
    <view class="polish-title">章节私密分享</view>
    <view class="polish-subtitle">只把这一章温柔地递给拿到链接的人</view>
  </view>

  <view class="share-preview polish-card">
    <view class="polish-card-content">
      <view class="share-status">{{mock.visibility}}</view>
      <view class="share-title">{{mock.title}}</view>
      <view class="share-date">{{mock.date}}</view>
      <view class="preview-strip">
        <view
          wx:for="{{mock.comicPreview}}"
          wx:key="id"
          class="preview-cover {{item.tone}}"
        >
          <view class="preview-sun"></view>
          <view class="preview-avatar"></view>
          <view class="preview-title">{{item.title}}</view>
        </view>
      </view>
      <view class="share-summary">{{mock.summary}}</view>
    </view>
  </view>

  <view class="link-card polish-card">
    <view class="polish-card-content">
      <view class="polish-card-title">{{mock.linkStatus}}</view>
      <view class="link-state">私密链接已准备好，可复制后发送给想分享的人</view>
      <view class="privacy-list">
        <view wx:for="{{mock.notes}}" wx:key="*this" class="privacy-line">{{item}}</view>
      </view>
    </view>
  </view>

  <view class="share-actions">
    <button class="polish-secondary" bindtap="copyLink" hover-class="polish-button-hover">复制链接</button>
    <button class="polish-primary" bindtap="shareToWechat" hover-class="polish-button-hover">微信分享</button>
  </view>

  <button class="back-home" bindtap="goHome">返回首页</button>
</view>
