page {
  min-height: 100%;
  background: #fffaf5;
}

button {
  margin: 0;
  padding: 0;
  background: transparent;
  border: 0;
  line-height: 1;
}

button::after {
  border: 0;
}

.share-preview {
  border-color: #f0b4a8;
  background: linear-gradient(180deg, #fffdf9 0%, #fff4ee 100%);
  box-shadow: 0 18rpx 36rpx rgba(210, 102, 92, 0.14);
}

.share-status {
  display: inline-flex;
  align-items: center;
  min-height: 50rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  color: #c66d75;
  font-size: 23rpx;
  background: #ffe8ea;
}

.share-title {
  margin-top: 20rpx;
  color: #4a2b22;
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.25;
}

.share-date {
  margin-top: 10rpx;
  color: #9b8176;
  font-size: 24rpx;
}

.preview-strip {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 24rpx;
}

.preview-cover {
  position: relative;
  height: 230rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.82);
  border-radius: 24rpx;
  overflow: hidden;
}

.preview-cover.sunny {
  background: linear-gradient(160deg, #bceaff 0%, #ffe9a7 62%, #bfe7ad 100%);
}

.preview-cover.home {
  background: linear-gradient(160deg, #ffe1c2 0%, #fff4df 50%, #cbe8df 100%);
}

.preview-sun {
  position: absolute;
  left: 22rpx;
  top: 22rpx;
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  background: #ffd96a;
}

.preview-avatar {
  position: absolute;
  left: 50%;
  top: 76rpx;
  width: 82rpx;
  height: 82rpx;
  border-radius: 50%;
  background: #ffd8c8;
  box-shadow: -18rpx -12rpx 0 rgba(184, 130, 96, 0.23), 0 54rpx 0 -24rpx #c6a9ee;
  transform: translateX(-50%);
}

.preview-title {
  position: absolute;
  left: 18rpx;
  right: 18rpx;
  bottom: 18rpx;
  padding: 12rpx;
  border-radius: 16rpx;
  color: #5c4037;
  font-size: 23rpx;
  font-weight: 800;
  text-align: center;
  background: rgba(255, 255, 255, 0.7);
}

.share-summary {
  margin-top: 22rpx;
  color: #715247;
  font-size: 26rpx;
  line-height: 1.65;
}

.link-card {
  background: #fff7e8;
}

.link-state {
  margin-top: 16rpx;
  padding: 18rpx;
  border-radius: 20rpx;
  color: #8d665c;
  font-size: 25rpx;
  line-height: 1.5;
  background: #fffdf9;
}

.privacy-list {
  margin-top: 18rpx;
}

.privacy-line {
  margin-top: 10rpx;
  color: #715247;
  font-size: 24rpx;
  line-height: 1.55;
}

.privacy-line::before {
  content: "";
  display: inline-block;
  width: 16rpx;
  height: 16rpx;
  margin-right: 10rpx;
  border-radius: 50%;
  background: #ff96a7;
}

.share-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.share-actions .polish-primary,
.share-actions .polish-secondary {
  width: 100%;
}

.back-home {
  margin: 26rpx auto 0;
  color: #8d7166;
  font-size: 26rpx;
}
