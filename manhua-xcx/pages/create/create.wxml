<view class="create-page">
  <view class="form-card">
    <view class="card-title-row">
      <text class="card-title">章节标题</text>
    </view>
    <view class="title-input-wrap">
      <input
        class="chapter-input"
        value="{{draftChapterTitle}}"
        placeholder="给今天的故事取个名字"
        placeholder-class="input-placeholder"
        maxlength="24"
        bindinput="onTitleInput"
      />
    </view>
  </view>

  <view class="form-card">
    <view class="card-title-row">
      <text class="card-title">日期</text>
    </view>
    <picker mode="date" value="{{diaryDateValue}}" bindchange="onDateChange">
      <view class="date-select">
        <text>{{diaryDateLabel}}</text>
      </view>
    </picker>
  </view>

  <view class="form-card choice-card">
    <view class="card-title-row">
      <text class="card-title">漫画页数</text>
    </view>
    <view class="page-count-control">
      <view
        class="random-option {{pageMode === 'random' ? 'is-selected' : ''}}"
        hover-class="option-hover"
        bindtap="selectRandomPageMode"
      >
        <text>随机生成</text>
      </view>
      <view class="page-count-input-wrap {{pageMode === 'custom' ? 'is-selected' : ''}}">
        <input
          class="page-count-input"
          type="number"
          maxlength="1"
          value="{{pageCountInput}}"
          placeholder="1-8页"
          placeholder-class="input-placeholder"
          bindinput="onPageCountInput"
          bindblur="onPageCountBlur"
        />
      </view>
    </view>
  </view>

  <view class="form-card choice-card">
    <view class="card-title-row">
      <text class="card-title">情绪标签</text>
    </view>
    <view class="tag-grid">
      <view
        wx:for="{{tagOptions}}"
        wx:key="value"
        class="tag-option {{item.selected ? 'is-selected' : ''}}"
        hover-class="option-hover"
        data-value="{{item.value}}"
        bindtap="toggleTag"
      >
        <text class="tag-label">{{item.label}}</text>
      </view>
    </view>
  </view>

  <view class="quota-line">
    <text>{{quotaHint}}：</text>
    <text class="quota-count">{{freeQuotaRemaining}}次</text>
  </view>

  <button class="next-button" hover-class="next-button-hover" bindtap="goNext">
    <text>下一步：填写日记</text>
  </button>
</view>
