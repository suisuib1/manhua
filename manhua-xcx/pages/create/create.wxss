page {
  min-height: 100%;
  background: #fffaf5;
  color: #4f3028;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

view,
text,
button,
input {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  background: transparent;
  line-height: normal;
  border: 0;
  border-radius: 0;
}

button::after {
  border: 0;
}

.create-page {
  width: 100%;
  min-height: 100vh;
  padding: 40rpx 24rpx 200rpx;
  box-sizing: border-box;
  overflow-x: hidden;
  background:
    radial-gradient(circle at 12% 4%, rgba(255, 226, 176, 0.34), transparent 210rpx),
    radial-gradient(circle at 86% 12%, rgba(255, 216, 224, 0.32), transparent 230rpx),
    #fffaf5;
}

.create-header {
  width: 100%;
  margin-bottom: 28rpx;
  text-align: center;
}

.page-title {
  color: #4a2b22;
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1.25;
}

.page-subtitle {
  margin-top: 12rpx;
  color: #76594f;
  font-size: 25rpx;
  line-height: 1.5;
}

.form-card {
  width: 100%;
  margin-bottom: 24rpx;
  padding: 26rpx;
  border-radius: 28rpx;
  background: #fffaf4;
  box-shadow: 0 14rpx 32rpx rgba(116, 76, 58, 0.08);
}

.choice-card {
  padding: 26rpx 22rpx 24rpx;
}

.card-title-row {
  display: flex;
  align-items: center;
  width: 100%;
}

.card-title {
  min-width: 0;
  color: #4d3029;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.35;
}

.title-input-wrap {
  display: flex;
  align-items: center;
  width: 100%;
  height: 88rpx;
  margin-top: 22rpx;
  padding: 0 24rpx;
  border-radius: 20rpx;
  background: #fff4ec;
}

.chapter-input {
  width: 100%;
  height: 88rpx;
  color: #6a382e;
  font-size: 29rpx;
}

.input-placeholder {
  color: #bea197;
}

.date-select {
  display: flex;
  align-items: center;
  width: 100%;
  min-height: 84rpx;
  margin-top: 22rpx;
  padding: 0 24rpx;
  border-radius: 20rpx;
  color: #68483e;
  font-size: 28rpx;
  background: #fff4ec;
}

.small-hint {
  margin-top: 14rpx;
  color: #9b8278;
  font-size: 23rpx;
  line-height: 1.5;
}

.mode-switch {
  display: flex;
  gap: 12rpx;
  width: 100%;
  margin-top: 24rpx;
  padding: 6rpx;
  border-radius: 999rpx;
  background: #fff3eb;
}

.mode-option {
  display: flex;
  flex: 1;
  align-items: center;
  justify-content: center;
  min-width: 0;
  height: 68rpx;
  border-radius: 999rpx;
  color: #87675d;
  font-size: 25rpx;
  font-weight: 700;
  background: transparent;
}

.mode-option.is-selected {
  color: #ef637c;
  background: #ffffff;
  box-shadow: 0 8rpx 18rpx rgba(239, 126, 144, 0.14);
}

.mode-label {
  max-width: 100%;
  overflow: hidden;
  text-align: center;
  white-space: nowrap;
}

.count-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12rpx;
  width: 100%;
  margin-top: 16rpx;
}

.count-option {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 0;
  height: 64rpx;
  padding: 0 4rpx;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  border-radius: 18rpx;
  color: #76554b;
  font-size: 24rpx;
  font-weight: 700;
  text-align: center;
  white-space: nowrap;
  background: #fff4ec;
}

.count-option.is-selected {
  border: 2rpx solid #f58298;
  color: #ef637c;
  background: #fff0f4;
}

.tag-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  width: 100%;
  margin-top: 24rpx;
}

.tag-option {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 0;
  height: 62rpx;
  padding: 0 6rpx;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  border-radius: 999rpx;
  color: #76554b;
  font-size: 24rpx;
  font-weight: 700;
  white-space: nowrap;
  background: #fff4ec;
}

.tag-option.is-selected {
  border: 2rpx solid #f4869b;
  color: #ee637c;
  background: #fff0f4;
}

.tag-label {
  min-width: 0;
  overflow: hidden;
  text-align: center;
  white-space: nowrap;
}

.note-card {
  width: 100%;
  margin-bottom: 22rpx;
  padding: 24rpx 28rpx;
  border-radius: 24rpx;
  color: #78584d;
  background: #fff5e5;
  box-shadow: 0 10rpx 24rpx rgba(146, 101, 62, 0.06);
}

.note-copy {
  font-size: 24rpx;
  line-height: 1.65;
}

.quota-line {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  margin: 2rpx auto 0;
  padding: 16rpx 24rpx;
  border-radius: 999rpx;
  color: #80645a;
  font-size: 25rpx;
  background: rgba(255, 247, 237, 0.92);
}

.quota-count {
  color: #f25f78;
  font-weight: 800;
}

.next-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 76%;
  height: 88rpx;
  margin: 28rpx auto 96rpx;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 29rpx;
  font-weight: 800;
  background: linear-gradient(180deg, #ff96a7 0%, #f77187 100%);
  box-shadow: 0 16rpx 30rpx rgba(238, 98, 119, 0.22);
}

.button-hover,
.option-hover,
.next-button-hover {
  opacity: 0.82;
}
