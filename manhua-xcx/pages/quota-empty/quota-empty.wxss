page {
  min-height: 100%;
  background: #fffaf5;
}

button {
  margin: 0;
  padding: 0;
  background: transparent;
  border: 0;
  line-height: 1;
}

button::after {
  border: 0;
}

.quota-page {
  padding-top: 52rpx;
}

.empty-card {
  text-align: center;
  border-color: #f0b4a8;
  background: linear-gradient(180deg, #fffdf9 0%, #fff4ee 100%);
  box-shadow: 0 18rpx 36rpx rgba(210, 102, 92, 0.14);
}

.empty-illustration {
  position: relative;
  height: 290rpx;
  margin-bottom: 24rpx;
  border-radius: 28rpx;
  overflow: hidden;
  background: linear-gradient(180deg, #fff4dc 0%, #fff0f4 100%);
}

.moon,
.sleep-cat-head,
.sleep-cat-body,
.bubble,
.soft-star {
  position: absolute;
}

.moon {
  right: 126rpx;
  top: 42rpx;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #ffd96a;
  box-shadow: -20rpx 0 0 #fff4dc;
}

.sleep-cat-head {
  left: 204rpx;
  bottom: 88rpx;
  width: 74rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #fffaf1;
  border: 3rpx solid #d9aa91;
}

.sleep-cat-body {
  left: 258rpx;
  bottom: 62rpx;
  width: 142rpx;
  height: 78rpx;
  border-radius: 50rpx;
  background: #fffaf1;
  border: 3rpx solid #d9aa91;
}

.bubble {
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.9);
}

.bubble-one {
  left: 112rpx;
  top: 78rpx;
  width: 42rpx;
  height: 42rpx;
}

.bubble-two {
  left: 164rpx;
  top: 48rpx;
  width: 24rpx;
  height: 24rpx;
}

.soft-star {
  left: 86rpx;
  bottom: 74rpx;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: #ffd66b;
}

.state-title {
  color: #4a2b22;
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.25;
}

.state-subtitle {
  margin-top: 18rpx;
  color: #715247;
  font-size: 26rpx;
  line-height: 1.65;
}

.reset-hint {
  margin-top: 20rpx;
  padding: 18rpx;
  border-radius: 20rpx;
  color: #9b6a76;
  font-size: 25rpx;
  line-height: 1.55;
  background: #fff1f4;
}

.tip-list {
  margin-top: 20rpx;
  padding: 18rpx;
  border-radius: 20rpx;
  background: #fff7e8;
}

.tip-line {
  color: #715247;
  font-size: 24rpx;
  line-height: 1.55;
}

.tip-line + .tip-line {
  margin-top: 8rpx;
}
