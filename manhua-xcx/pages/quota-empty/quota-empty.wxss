page {
  min-height: 100%;
  background: #fffaf5;
}

button {
  margin: 0;
  padding: 0;
  background: transparent;
  border: 0;
  line-height: 1;
}

button::after {
  border: 0;
}

.quota-page {
  padding-top: 52rpx;
}

.empty-card {
  text-align: center;
  border-color: #f0b4a8;
  background: linear-gradient(180deg, #fffdf9 0%, #fff4ee 100%);
  box-shadow: 0 18rpx 36rpx rgba(210, 102, 92, 0.14);
}

.empty-illustration {
  position: relative;
  height: 290rpx;
  margin-bottom: 24rpx;
  border-radius: 28rpx;
  overflow: hidden;
  background: linear-gradient(180deg, #fff4dc 0%, #fff0f4 100%);
}

.empty-image {
  display: block;
  width: 100%;
  height: 100%;
}

.state-title {
  color: #4a2b22;
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.25;
}

.state-subtitle {
  margin-top: 18rpx;
  color: #715247;
  font-size: 26rpx;
  line-height: 1.65;
}

.reset-hint {
  margin-top: 20rpx;
  padding: 18rpx;
  border-radius: 20rpx;
  color: #9b6a76;
  font-size: 25rpx;
  line-height: 1.55;
  background: #fff1f4;
}

.tip-list {
  margin-top: 20rpx;
  padding: 18rpx;
  border-radius: 20rpx;
  background: #fff7e8;
}

.tip-line {
  color: #715247;
  font-size: 24rpx;
  line-height: 1.55;
}

.tip-line + .tip-line {
  margin-top: 8rpx;
}
