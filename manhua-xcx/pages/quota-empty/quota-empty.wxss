page {
  min-height: 100%;
  background: #fffaf5;
  color: #50332a;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

button {
  margin: 0;
  padding: 0;
  background: transparent;
  border: 0;
}

button::after {
  border: 0;
}

.quota-page {
  min-height: 100vh;
  padding: 52rpx 28rpx 58rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 12% 8%, rgba(255, 226, 176, 0.35), transparent 220rpx),
    radial-gradient(circle at 88% 14%, rgba(255, 216, 224, 0.38), transparent 260rpx),
    #fffaf5;
}

.state-card,
.tips-card {
  padding: 30rpx;
  border: 2rpx solid #efd9cc;
  border-radius: 34rpx;
  text-align: center;
  background: rgba(255, 254, 250, 0.94);
  box-shadow: 0 12rpx 30rpx rgba(114, 75, 54, 0.09);
}

.state-illustration {
  position: relative;
  height: 260rpx;
  margin-bottom: 18rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, #fff4dc 0%, #fff0f4 100%);
  overflow: hidden;
}

.moon,
.sleep-cat-head,
.sleep-cat-body,
.bubble {
  position: absolute;
}

.moon {
  right: 112rpx;
  top: 42rpx;
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  background: #ffd96a;
  box-shadow: -18rpx 0 0 #fff4dc;
}

.sleep-cat-head {
  left: 206rpx;
  bottom: 80rpx;
  width: 70rpx;
  height: 62rpx;
  border-radius: 50%;
  background: #fffaf1;
  border: 3rpx solid #d9aa91;
}

.sleep-cat-body {
  left: 258rpx;
  bottom: 56rpx;
  width: 136rpx;
  height: 76rpx;
  border-radius: 48rpx;
  background: #fffaf1;
  border: 3rpx solid #d9aa91;
}

.bubble {
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.9);
}

.bubble-one {
  left: 112rpx;
  top: 72rpx;
  width: 42rpx;
  height: 42rpx;
}

.bubble-two {
  left: 164rpx;
  top: 44rpx;
  width: 24rpx;
  height: 24rpx;
}

.state-title {
  color: #4a2b22;
  font-size: 40rpx;
  font-weight: 800;
}

.state-subtitle,
.reset-hint,
.tip-line {
  color: #715247;
  font-size: 26rpx;
  line-height: 1.65;
}

.state-subtitle {
  margin-top: 18rpx;
}

.reset-hint {
  margin-top: 20rpx;
  padding: 18rpx;
  border-radius: 20rpx;
  color: #9b6a76;
  background: #fff1f4;
}

.tips-card {
  margin-top: 28rpx;
  text-align: left;
  background: #fff7e8;
}

.tips-title {
  color: #4d3029;
  font-size: 30rpx;
  font-weight: 800;
}

.tip-line {
  margin-top: 14rpx;
}

.primary-button,
.secondary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 620rpx;
  max-width: 100%;
  height: 96rpx;
  margin: 30rpx auto 0;
  border-radius: 999rpx;
  font-size: 32rpx;
  font-weight: 800;
}

.primary-button {
  border: 4rpx solid #ffffff;
  color: #ffffff;
  background: linear-gradient(180deg, #ff96a7 0%, #f77187 100%);
  box-shadow: 0 16rpx 30rpx rgba(238, 98, 119, 0.23);
}

.secondary-button {
  margin-top: 18rpx;
  border: 2rpx solid #f0d6c8;
  color: #7b5b51;
  background: #fffdf9;
}

.button-hover {
  opacity: 0.86;
}
