<view class="quota-page polish-page">
  <view class="empty-card polish-card">
    <view class="polish-card-content">
      <view class="empty-illustration">
        <view class="moon"></view>
        <view class="sleep-cat-head"></view>
        <view class="sleep-cat-body"></view>
        <view class="bubble bubble-one"></view>
        <view class="bubble bubble-two"></view>
        <view class="soft-star"></view>
      </view>

      <view class="state-title">{{mock.title}}</view>
      <view class="state-subtitle">{{mock.subtitle}}</view>
      <view class="reset-hint">{{mock.resetHint}}</view>

      <view class="tip-list">
        <view wx:for="{{mock.tips}}" wx:key="*this" class="tip-line">{{item}}</view>
      </view>
    </view>
  </view>

  <button class="polish-primary" bindtap="goHome" hover-class="polish-button-hover">
    {{mock.actions.home}}
  </button>
  <button class="polish-secondary" bindtap="viewChapter" hover-class="polish-button-hover">
    {{mock.actions.chapter}}
  </button>
</view>
