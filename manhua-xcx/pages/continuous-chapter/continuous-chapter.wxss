page {
  min-height: 100%;
  background: #fff6ea;
}

button {
  margin: 0;
  padding: 0;
  background: transparent;
  border: 0;
  line-height: 1;
}

button::after {
  border: 0;
}

.reader-page {
  min-height: 100vh;
  padding: 12rpx 24rpx 38rpx;
  box-sizing: border-box;
  color: #4a2b22;
  background:
    radial-gradient(circle at 12% 4%, rgba(255, 205, 215, 0.36), transparent 230rpx),
    radial-gradient(circle at 90% 10%, rgba(255, 224, 180, 0.46), transparent 260rpx),
    #fff6ea;
}

.page-shell {
  min-height: 1040rpx;
  padding: 18rpx 8rpx 24rpx;
  box-sizing: border-box;
}

.comic-page-card {
  position: relative;
  min-height: 940rpx;
  padding: 28rpx 24rpx 32rpx;
  box-sizing: border-box;
  overflow: hidden;
  border-radius: 36rpx;
  background: #fffdf8;
  box-shadow:
    inset 12rpx 0 22rpx rgba(224, 190, 152, 0.2),
    0 24rpx 48rpx rgba(116, 69, 52, 0.13);
}

.page-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.chapter-title {
  min-width: 0;
  color: #6a3c31;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.35;
}

.chapter-date {
  flex-shrink: 0;
  color: #a47b70;
  font-size: 22rpx;
  line-height: 1.35;
}

.comic-image {
  display: block;
  width: 100%;
  min-height: 760rpx;
  border-radius: 28rpx;
  background: #fff6ea;
  box-shadow: inset 0 0 0 4rpx rgba(255, 255, 255, 0.62);
}

.page-number {
  display: table;
  min-width: 180rpx;
  margin: 28rpx auto 0;
  padding: 12rpx 26rpx;
  border-radius: 999rpx;
  color: #8a5f55;
  font-size: 26rpx;
  font-weight: 800;
  text-align: center;
  background: #fff6ea;
  box-shadow: 0 12rpx 22rpx rgba(116, 69, 52, 0.08);
}

.empty-card {
  min-height: 720rpx;
  padding: 80rpx 40rpx;
  border-radius: 36rpx;
  box-sizing: border-box;
  text-align: center;
  background: rgba(255, 255, 255, 0.78);
  box-shadow: 0 18rpx 38rpx rgba(116, 69, 52, 0.1);
}

.empty-title {
  color: #6a3c31;
  font-size: 32rpx;
  font-weight: 900;
}

.empty-text {
  margin-top: 16rpx;
  color: #a47b70;
  font-size: 25rpx;
}

.reader-bottom {
  display: flex;
  justify-content: space-between;
  padding: 0 42rpx calc(28rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.nav-hint {
  color: #9a7064;
  font-size: 24rpx;
  font-weight: 800;
}

.finished-card {
  margin: 10rpx 8rpx 0;
  padding: 22rpx 24rpx;
  border-radius: 28rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.78);
  box-shadow: 0 14rpx 30rpx rgba(116, 69, 52, 0.1);
}

.finished-title {
  color: #7a5048;
  font-size: 25rpx;
  font-weight: 800;
}

.cover-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 260rpx;
  height: 68rpx;
  margin: 18rpx auto 0;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 900;
  background: #f86f91;
}
