<view class="reader-page">
  <view class="reader-topbar">
    <button class="reader-back" bindtap="backToCover" hover-class="reader-back-hover">‹</button>
    <view class="reader-title">{{currentPage.chapterTitle || '漫画阅读'}}</view>
  </view>

  <view class="reader-canvas" bindtouchstart="handleTouchStart" bindtouchend="handleTouchEnd">
    <view wx:if="{{currentPage && currentPage.image}}" class="comic-page">
      <image class="comic-image" src="{{currentPage.image}}" mode="widthFix" />
    </view>

    <view wx:else class="empty-state">
      <image class="empty-image" src="/subpackage/icon-home-mascot-star.png" mode="widthFix" />
      <view class="empty-title">暂无漫画图片</view>
      <view class="empty-text">请先生成漫画章节</view>
    </view>
  </view>

  <view wx:if="{{currentPage}}" class="page-number">{{progressText}}</view>
</view>
