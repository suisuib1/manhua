<view class="generating-page polish-page">
  <view class="polish-header">
    <view class="polish-title">{{mock.title}}</view>
    <view class="polish-subtitle">{{mock.subtitle}}</view>
  </view>

  <view class="stage-card polish-card">
    <view class="polish-card-content">
      <view class="binder-row">
        <view class="binder"></view>
        <view class="binder"></view>
        <view class="binder"></view>
        <view class="binder"></view>
        <view class="binder"></view>
      </view>
      <view class="stage-illustration">
        <image class="stage-image" src="/subpackage/icon-home-mascot-star.png" mode="aspectFit" />
        <view class="stage-star star-a"></view>
        <view class="stage-star star-b"></view>
      </view>
      <view class="stage-title">正在为你整理今天的漫画页...</view>
      <view class="chapter-pill">当前章节：{{mock.chapterTitle}}</view>
    </view>
  </view>

  <view class="progress-card polish-card">
    <view class="polish-card-content">
      <view class="step-track">
        <view wx:for="{{mock.steps}}" wx:key="id" class="track-item {{index <= activeStepIndex ? 'is-active' : ''}}">
          <view class="track-dot">{{index + 1}}</view>
          <view class="track-label">{{item.label}}</view>
        </view>
      </view>
      <view class="soft-progress">
        <view class="soft-progress-fill" style="width: {{progress}}%;"></view>
      </view>
      <view class="wait-pill">{{mock.estimatedText}}</view>
    </view>
  </view>

  <view class="polish-note wait-note">
    你可以先去做其他可爱的事，回来时这一章会继续为你生成中。
  </view>

  <button
    wx:if="{{canViewChapter}}"
    class="polish-primary"
    bindtap="goChapterDetail"
    hover-class="polish-button-hover"
  >
    查看生成章节
  </button>
  <button
    wx:else
    class="polish-secondary"
    bindtap="retryTask"
    hover-class="polish-button-hover"
  >
    返回漫画书
  </button>
</view>
