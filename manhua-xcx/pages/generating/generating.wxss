page {
  min-height: 100%;
  background: #fffaf5;
}

button {
  margin: 0;
  padding: 0;
  background: transparent;
  border: 0;
  line-height: 1;
}

button::after {
  border: 0;
}

.stage-card {
  min-height: 640rpx;
  padding-top: 46rpx;
  border-radius: 40rpx;
  background: linear-gradient(180deg, #fffdf9 0%, #fff4ee 100%);
}

.binder-row {
  position: absolute;
  left: 46rpx;
  right: 46rpx;
  top: -28rpx;
  display: flex;
  justify-content: space-between;
}

.binder {
  width: 28rpx;
  height: 70rpx;
  border: 5rpx solid #efaa9f;
  border-bottom: 0;
  border-radius: 20rpx 20rpx 0 0;
  background: #fffaf5;
}

.stage-illustration {
  position: relative;
  height: 330rpx;
  margin-top: 18rpx;
}

.comic-sheet {
  position: absolute;
  left: 58rpx;
  top: 52rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 6rpx;
  width: 122rpx;
  height: 146rpx;
  padding: 10rpx;
  box-sizing: border-box;
  border: 4rpx solid #b98372;
  border-radius: 12rpx;
  background: #fff7ef;
  transform: rotate(-14deg);
}

.sheet-panel {
  border-radius: 8rpx;
  background: linear-gradient(160deg, #cfeeff 0%, #fff0c6 100%);
}

.girl-head,
.girl-body,
.cat-nap,
.stage-star {
  position: absolute;
}

.girl-head {
  left: 50%;
  top: 36rpx;
  width: 184rpx;
  height: 174rpx;
  border-radius: 50%;
  background: #ffd8c8;
  box-shadow: -36rpx -24rpx 0 rgba(184, 130, 96, 0.24);
  transform: translateX(-50%);
}

.girl-head::before,
.girl-head::after {
  content: "";
  position: absolute;
  top: 82rpx;
  width: 16rpx;
  height: 22rpx;
  border-radius: 50%;
  background: #5c3c35;
}

.girl-head::before {
  left: 58rpx;
}

.girl-head::after {
  right: 54rpx;
}

.girl-body {
  left: 50%;
  bottom: 32rpx;
  width: 162rpx;
  height: 92rpx;
  border-radius: 60rpx 60rpx 28rpx 28rpx;
  background: #c6a9ee;
  transform: translateX(-50%);
}

.cat-nap {
  right: 74rpx;
  bottom: 46rpx;
  width: 128rpx;
  height: 62rpx;
  border: 3rpx solid #d9aa91;
  border-radius: 48rpx;
  background: #fffaf1;
}

.stage-star {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: #ffd66b;
}

.star-a {
  left: 154rpx;
  top: 42rpx;
}

.star-b {
  right: 116rpx;
  top: 116rpx;
  background: #ff9daf;
}

.stage-title {
  margin-top: 10rpx;
  color: #4d3029;
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1.35;
  text-align: center;
}

.chapter-pill,
.wait-pill {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 72rpx;
  margin: 24rpx auto 0;
  padding: 0 28rpx;
  box-sizing: border-box;
  border: 2rpx solid #f1d5cc;
  border-radius: 22rpx;
  color: #6a4339;
  font-size: 26rpx;
  background: #fffdf9;
}

.progress-card {
  background: rgba(255, 254, 250, 0.96);
}

.step-track {
  display: flex;
  justify-content: space-between;
  gap: 8rpx;
}

.track-item {
  flex: 1;
  min-width: 0;
  text-align: center;
  opacity: 0.46;
}

.track-item.is-active {
  opacity: 1;
}

.track-dot {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  height: 58rpx;
  margin: 0 auto;
  border-radius: 50%;
  color: #9c8176;
  font-size: 24rpx;
  background: #f4e5dc;
}

.track-item.is-active .track-dot {
  color: #ffffff;
  background: #ff8fa2;
}

.track-label {
  margin-top: 12rpx;
  color: #6f5148;
  font-size: 21rpx;
  line-height: 1.25;
}

.soft-progress {
  height: 18rpx;
  margin-top: 28rpx;
  border-radius: 999rpx;
  background: #f3e2d9;
  overflow: hidden;
}

.soft-progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #ff96a7 0%, #ffc46f 100%);
}

.wait-pill {
  width: 440rpx;
  min-height: 58rpx;
  color: #4c7d9e;
  background: #eef6ff;
  border-color: #d9e9fb;
}

.wait-note {
  text-align: center;
}
