page {
  min-height: 100%;
  background: #fffaf5;
  color: #50332a;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

button {
  margin: 0;
  padding: 0;
  background: transparent;
  border: 0;
}

button::after {
  border: 0;
}

.generating-page {
  min-height: 100vh;
  padding: 36rpx 28rpx 58rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 12% 8%, rgba(255, 226, 176, 0.36), transparent 220rpx),
    radial-gradient(circle at 86% 18%, rgba(255, 216, 224, 0.36), transparent 260rpx),
    #fffaf5;
}

.page-header {
  text-align: center;
}

.page-title {
  color: #4a2b22;
  font-size: 40rpx;
  font-weight: 800;
}

.page-subtitle {
  margin-top: 18rpx;
  color: #75574c;
  font-size: 26rpx;
}

.wait-illustration {
  position: relative;
  height: 300rpx;
  margin-top: 28rpx;
  border: 2rpx solid #efd9cc;
  border-radius: 36rpx;
  overflow: hidden;
  background: linear-gradient(180deg, #fffdf9 0%, #fff0e4 100%);
  box-shadow: 0 12rpx 30rpx rgba(114, 75, 54, 0.09);
}

.cloud,
.spark,
.mascot-head,
.mascot-body {
  position: absolute;
}

.cloud {
  width: 112rpx;
  height: 48rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.9);
}

.cloud-one {
  left: 72rpx;
  top: 54rpx;
}

.cloud-two {
  right: 62rpx;
  top: 98rpx;
  width: 88rpx;
}

.mascot-head {
  left: 50%;
  top: 86rpx;
  width: 124rpx;
  height: 118rpx;
  border-radius: 50%;
  background: #ffd8c8;
  box-shadow: -28rpx -18rpx 0 rgba(184, 130, 96, 0.24);
  transform: translateX(-50%);
}

.mascot-head::before,
.mascot-head::after {
  content: "";
  position: absolute;
  top: 54rpx;
  width: 12rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #5c3c35;
}

.mascot-head::before {
  left: 38rpx;
}

.mascot-head::after {
  right: 34rpx;
}

.mascot-body {
  left: 50%;
  bottom: 34rpx;
  width: 106rpx;
  height: 62rpx;
  border-radius: 44rpx 44rpx 22rpx 22rpx;
  background: #c6a9ee;
  transform: translateX(-50%);
}

.spark {
  width: 26rpx;
  height: 26rpx;
  border-radius: 50%;
  background: #ffd66b;
}

.spark-one {
  left: 186rpx;
  top: 82rpx;
}

.spark-two {
  right: 176rpx;
  bottom: 82rpx;
  background: #ff9daf;
}

.progress-card,
.steps-card {
  margin-top: 28rpx;
  padding: 28rpx;
  border: 2rpx solid #efd9cc;
  border-radius: 30rpx;
  background: rgba(255, 254, 250, 0.94);
  box-shadow: 0 12rpx 30rpx rgba(114, 75, 54, 0.09);
}

.progress-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.status-label,
.task-meta,
.step-detail {
  color: #a68b80;
  font-size: 23rpx;
}

.chapter-title,
.card-title,
.step-title {
  color: #4d3029;
  font-size: 30rpx;
  font-weight: 800;
}

.chapter-title {
  margin-top: 10rpx;
}

.progress-number {
  color: #ef6e83;
  font-size: 42rpx;
  font-weight: 800;
}

.progress-track {
  height: 20rpx;
  margin-top: 26rpx;
  border-radius: 999rpx;
  background: #f3e2d9;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #ff96a7 0%, #ffc46f 100%);
}

.task-meta {
  display: flex;
  justify-content: space-between;
  margin-top: 18rpx;
}

.step-row {
  display: flex;
  align-items: center;
  margin-top: 22rpx;
  opacity: 0.54;
}

.step-row.is-active {
  opacity: 1;
}

.step-dot {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 54rpx;
  width: 54rpx;
  height: 54rpx;
  margin-right: 18rpx;
  border-radius: 50%;
  color: #9c8176;
  font-size: 24rpx;
  background: #f4e5dc;
}

.step-row.is-active .step-dot {
  color: #ffffff;
  background: #ff8fa2;
}

.step-detail {
  margin-top: 6rpx;
}

.primary-button,
.secondary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 620rpx;
  max-width: 100%;
  height: 96rpx;
  margin: 32rpx auto 0;
  border-radius: 999rpx;
  font-size: 32rpx;
  font-weight: 800;
}

.primary-button {
  border: 4rpx solid #ffffff;
  color: #ffffff;
  background: linear-gradient(180deg, #ff96a7 0%, #f77187 100%);
  box-shadow: 0 16rpx 30rpx rgba(238, 98, 119, 0.23);
}

.secondary-button {
  border: 2rpx solid #f0d6c8;
  color: #8d6f64;
  background: #fffdf9;
}

.primary-hover,
.secondary-hover {
  opacity: 0.86;
}
