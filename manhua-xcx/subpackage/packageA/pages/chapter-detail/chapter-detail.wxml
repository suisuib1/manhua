<view class="detail-page polish-page">
  <view class="chapter-hero polish-card">
    <view class="polish-card-content">
      <view class="hero-top">
        <view class="privacy-pill">{{mock.privacyLabel}}</view>
        <view class="chapter-date">{{mock.date}}</view>
      </view>
      <view class="chapter-title">{{mock.title}}</view>
      <view class="polish-chip-row hero-tags">
        <text wx:for="{{mock.tags}}" wx:key="*this" class="polish-chip">#{{item}}</text>
      </view>
    </view>
  </view>

  <view class="reader-list">
    <view
      wx:for="{{mock.comicPages}}"
      wx:key="id"
      class="reader-card polish-card"
    >
      <view class="polish-card-content">
        <view class="comic-page-head">
          <view class="polish-card-title">{{item.title}}</view>
          <view class="page-label">Q版分镜</view>
        </view>
        <view class="comic-sheet {{item.tone}}">
          <view
            wx:for="{{item.panels}}"
            wx:for-item="panel"
            wx:key="*this"
            class="comic-panel"
          >
            <image class="comic-panel-image" src="/subpackage/icon-home-mascot-star.png" mode="aspectFill" />
            <view class="panel-text">{{panel}}</view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="summary-card polish-card">
    <view class="polish-card-content">
      <view class="polish-card-title">章节摘要</view>
      <view class="polish-card-desc">{{mock.summary}}</view>
      <view class="privacy-note">{{mock.privacyNote}}</view>
    </view>
  </view>

  <button class="polish-primary" bindtap="goShare" hover-class="polish-button-hover">私密分享这一章</button>
  <view class="action-row">
    <button class="soft-action" bindtap="regenerateChapter" hover-class="polish-button-hover">重新生成</button>
    <button class="soft-action danger" bindtap="confirmDelete" hover-class="polish-button-hover">删除章节</button>
  </view>
</view>
