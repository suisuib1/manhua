page {
  min-height: 100%;
  background: #fffaf5;
}

button {
  margin: 0;
  padding: 0;
  background: transparent;
  border: 0;
  line-height: 1;
}

button::after {
  border: 0;
}

.chapter-hero {
  margin-top: 14rpx;
  border-color: #f0b4a8;
  background: linear-gradient(180deg, #fffdf9 0%, #fff4ee 100%);
  box-shadow: 0 18rpx 36rpx rgba(210, 102, 92, 0.14);
}

.hero-top,
.comic-page-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.privacy-pill,
.page-label {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 50rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  color: #c66d75;
  font-size: 23rpx;
  background: #ffe8ea;
}

.chapter-date {
  color: #9b8176;
  font-size: 24rpx;
}

.chapter-title {
  margin-top: 24rpx;
  color: #4a2b22;
  font-size: 44rpx;
  font-weight: 800;
  line-height: 1.25;
}

.hero-tags {
  margin-top: 20rpx;
}

.reader-list {
  margin-top: 26rpx;
}

.reader-card {
  margin-top: 24rpx;
  padding: 26rpx;
  background: rgba(255, 254, 250, 0.96);
}

.comic-sheet {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  min-height: 560rpx;
  margin-top: 22rpx;
  padding: 18rpx;
  box-sizing: border-box;
  border: 3rpx solid #ffffff;
  border-radius: 28rpx;
  overflow: hidden;
}

.comic-sheet.sunny {
  background: linear-gradient(160deg, #bceaff 0%, #ffe9a7 58%, #bfe7ad 100%);
}

.comic-sheet.home {
  background: linear-gradient(160deg, #ffe1c2 0%, #fff4df 54%, #cbe8df 100%);
}

.comic-panel {
  position: relative;
  min-height: 250rpx;
  box-sizing: border-box;
  border: 4rpx solid rgba(255, 255, 255, 0.82);
  border-radius: 22rpx;
  overflow: hidden;
}

.comic-panel-image {
  display: block;
  width: 100%;
  height: 100%;
  min-height: 250rpx;
}

.panel-text {
  position: absolute;
  left: 20rpx;
  right: 20rpx;
  bottom: 20rpx;
  z-index: 1;
  padding: 12rpx 10rpx;
  border-radius: 16rpx;
  color: #5c4037;
  font-size: 25rpx;
  font-weight: 800;
  text-align: center;
  background: rgba(255, 255, 255, 0.68);
}

.summary-card {
  background: #fff7e8;
}

.privacy-note {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 20rpx;
  color: #9b6a76;
  font-size: 24rpx;
  line-height: 1.55;
  background: #fff1f4;
}

.action-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 18rpx;
}

.soft-action {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 82rpx;
  border: 2rpx solid #f0d6c8;
  border-radius: 999rpx;
  color: #7b5b51;
  font-size: 27rpx;
  font-weight: 700;
  background: rgba(255, 253, 249, 0.92);
}

.soft-action.danger {
  color: #bf6b70;
}
