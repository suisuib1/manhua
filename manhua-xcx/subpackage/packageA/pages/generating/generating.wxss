page {
  min-height: 100%;
  background: #fffaf5;
}

button {
  margin: 0;
  padding: 0;
  background: transparent;
  border: 0;
  line-height: 1;
}

button::after {
  border: 0;
}

.stage-card {
  min-height: 640rpx;
  border-radius: 40rpx;
  background: linear-gradient(180deg, #fffdf9 0%, #fff4ee 100%);
}

.stage-illustration {
  position: relative;
  height: 330rpx;
  margin-top: 18rpx;
}

.stage-star {
  position: absolute;
}

.stage-image {
  position: absolute;
  left: 50%;
  top: 8rpx;
  width: 260rpx;
  height: 260rpx;
  transform: translateX(-50%);
}

.stage-star {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: #ffd66b;
}

.star-a {
  left: 154rpx;
  top: 42rpx;
}

.star-b {
  right: 116rpx;
  top: 116rpx;
  background: #ff9daf;
}

.stage-title {
  margin-top: 10rpx;
  color: #4d3029;
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1.35;
  text-align: center;
}

.chapter-pill,
.wait-pill {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 72rpx;
  margin: 24rpx auto 0;
  padding: 0 28rpx;
  box-sizing: border-box;
  border: 2rpx solid #f1d5cc;
  border-radius: 22rpx;
  color: #6a4339;
  font-size: 26rpx;
  background: #fffdf9;
}

.progress-card {
  background: rgba(255, 254, 250, 0.96);
}

.step-track {
  display: flex;
  justify-content: space-between;
  gap: 8rpx;
}

.track-item {
  flex: 1;
  min-width: 0;
  text-align: center;
  opacity: 0.46;
}

.track-item.is-active {
  opacity: 1;
}

.track-dot {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  height: 58rpx;
  margin: 0 auto;
  border-radius: 50%;
  color: #9c8176;
  font-size: 24rpx;
  background: #f4e5dc;
}

.track-item.is-active .track-dot {
  color: #ffffff;
  background: #ff8fa2;
}

.track-label {
  margin-top: 12rpx;
  color: #6f5148;
  font-size: 21rpx;
  line-height: 1.25;
}

.soft-progress {
  height: 18rpx;
  margin-top: 28rpx;
  border-radius: 999rpx;
  background: #f3e2d9;
  overflow: hidden;
}

.soft-progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #ff96a7 0%, #ffc46f 100%);
}

.wait-pill {
  width: 440rpx;
  min-height: 58rpx;
  color: #4c7d9e;
  background: #eef6ff;
  border-color: #d9e9fb;
}
