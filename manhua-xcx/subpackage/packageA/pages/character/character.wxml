<view class="character-page polish-page">
  <view class="profile-cover polish-card">
    <view class="polish-card-content cover-content">
      <view class="profile-photo">
        <image class="profile-image" src="/subpackage/icon-home-mascot-star.png" mode="aspectFill" />
      </view>
      <view class="cover-copy">
        <view class="cover-kicker">角色档案会帮助漫画保持人物一致</view>
        <view class="cover-title">{{nickname}}</view>
        <view class="cover-desc">{{roleTitle}}</view>
      </view>
      <view class="cover-star star-one"></view>
      <view class="cover-star star-two"></view>
    </view>
  </view>

  <view class="profile-form polish-card">
    <view class="polish-card-content">
      <view class="form-grid">
        <view class="field-block">
          <view class="field-label">主角昵称</view>
          <input
            class="field-input"
            value="{{nickname}}"
            placeholder="给主角取个名字"
            bindinput="onNicknameInput"
          />
        </view>
        <view class="field-block">
          <view class="field-label">身份关系</view>
          <view class="field-static">{{roleTitle}}</view>
        </view>
      </view>

      <view class="field-block full-field">
        <view class="field-label">角色描述</view>
        <textarea
          class="desc-input"
          value="{{description}}"
          maxlength="120"
          placeholder="描述发型、衣服、常见表情或你想保持一致的特征"
          placeholder-class="input-placeholder"
          bindinput="onDescriptionInput"
        />
      </view>

      <view class="input-section">
        <view class="field-label">性格关键词</view>
        <textarea
          class="trait-input personality-input"
          value="{{personalityText}}"
          maxlength="80"
          placeholder="例如：温柔、好奇、爱笑"
          placeholder-class="input-placeholder"
          bindinput="onPersonalityInput"
        />
      </view>

      <view class="input-section">
        <view class="field-label">外观特征</view>
        <textarea
          class="trait-input appearance-input"
          value="{{appearanceText}}"
          maxlength="100"
          placeholder="例如：短发、圆眼睛、喜欢穿蓝色外套"
          placeholder-class="input-placeholder"
          bindinput="onAppearanceInput"
        />
      </view>

      <view class="reference-section">
        <view class="field-label">主角形象参考图</view>
        <view class="reference-single" bindtap="chooseReferenceImage" hover-class="polish-button-hover">
          <image class="reference-card" src="{{referenceImage}}" mode="aspectFill" />
          <view class="reference-hint">点击替换</view>
        </view>
      </view>
    </view>
  </view>

  <view class="character-note polish-note">
    <view wx:for="{{mock.notes}}" wx:key="*this" class="note-line">{{item}}</view>
  </view>

  <button class="polish-primary" bindtap="saveCharacter" hover-class="polish-button-hover">
    保存角色档案
  </button>
</view>
