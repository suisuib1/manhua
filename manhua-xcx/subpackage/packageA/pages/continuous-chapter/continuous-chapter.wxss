page {
  min-height: 100%;
  background: #f7f3ec;
}

button {
  margin: 0;
  padding: 0;
  background: transparent;
  border: 0;
  line-height: 1;
}

button::after {
  border: 0;
}

.reader-page {
  min-height: 100vh;
  padding: 0 0 calc(72rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  color: #2f2925;
  background: #f7f3ec;
}

.reader-canvas {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: calc(100vh - 72rpx - env(safe-area-inset-bottom));
  padding: 0;
  box-sizing: border-box;
}

.comic-page {
  width: 100%;
}

.comic-image {
  display: block;
  width: 100%;
  height: auto;
  background: #f7f3ec;
}

.page-number {
  position: fixed;
  left: 50%;
  bottom: calc(22rpx + env(safe-area-inset-bottom));
  z-index: 3;
  min-width: 104rpx;
  padding: 8rpx 20rpx;
  transform: translateX(-50%);
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 23rpx;
  font-weight: 700;
  text-align: center;
  background: rgba(35, 31, 28, 0.62);
}

.empty-state {
  width: 100%;
  padding: 120rpx 56rpx;
  text-align: center;
  box-sizing: border-box;
}

.empty-image {
  display: block;
  width: 260rpx;
  height: auto;
  margin: 0 auto 28rpx;
}

.empty-title {
  color: #3a312c;
  font-size: 32rpx;
  font-weight: 800;
}

.empty-text {
  margin-top: 16rpx;
  color: #8d7d72;
  font-size: 25rpx;
}

.finished-card {
  margin: 10rpx 8rpx 0;
  padding: 22rpx 24rpx;
  border-radius: 28rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.78);
  box-shadow: 0 14rpx 30rpx rgba(116, 69, 52, 0.1);
}

.finished-title {
  color: #7a5048;
  font-size: 25rpx;
  font-weight: 800;
}

.cover-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 260rpx;
  height: 68rpx;
  margin: 18rpx auto 0;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 900;
  background: #f86f91;
}
